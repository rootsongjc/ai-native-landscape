---
import '../styles/global.css';
import { alternatePath, localizedPath, SITE, ui } from '../lib/landscape.mjs';
import SearchModal from '../components/SearchModal.astro';

const {
  title = SITE.title,
  description = SITE.description,
  canonical = Astro.url.pathname,
  lang = 'en',
  alternate = alternatePath(Astro.url.pathname, lang),
} = Astro.props;

const copy = ui(lang);
const siteTitle = lang === 'zh' ? copy.landscapeTitle : SITE.title;
const isHomePage = !title || title === SITE.title;
const pageTitle = isHomePage
  ? (lang === 'zh' ? copy.homePageTitle : SITE.title)
  : `${title} | ${siteTitle}`;
const canonicalUrl = new URL(canonical, SITE.url).toString();
const alternateUrl = new URL(alternate, SITE.url).toString();
const defaultUrl = lang === 'zh' ? alternateUrl : canonicalUrl;
const imageUrl = new URL(SITE.image, SITE.url).toString();
const imageSquareUrl = new URL(SITE.imageSquare, SITE.url).toString();
const locale = lang === 'zh' ? 'zh_CN' : 'en_US';
const alternateLocale = lang === 'zh' ? 'en_US' : 'zh_CN';
const selfHreflang = lang === 'zh' ? 'zh-CN' : 'en';
const alternateHreflang = lang === 'zh' ? 'en' : 'zh-CN';
const currentYear = new Date().getFullYear();
const footerCopyright = `© ${SITE.copyrightStartYear}-${currentYear} Jimmy Song All Rights Reserved`;
const mainSiteBase = lang === 'zh' ? `${SITE.mainSite}/zh` : SITE.mainSite;
const footerBlogUrl = `${mainSiteBase}/blog`;
const footerBookUrl = `${mainSiteBase}/book`;
const languageOptions = [
  { code: 'en', label: 'English', href: localizedPath(canonical, 'en') },
  { code: 'zh', label: '中文', href: localizedPath(canonical, 'zh') },
];
const currentLanguage = languageOptions.find((option) => option.code === lang) || languageOptions[0];
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.title,
  url: SITE.url,
  description,
  inLanguage: copy.htmlLang,
  publisher: {
    '@type': 'Organization',
    name: 'jimmysong.io',
    url: 'https://jimmysong.io',
  },
};
---

<!doctype html>
<html lang={copy.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={selfHreflang} href={canonicalUrl} />
    <link rel="alternate" hreflang={alternateHreflang} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={defaultUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://api.github.com" crossorigin />
    <link rel="preconnect" href={SITE.scoreApiBase} crossorigin />
    <meta name="theme-color" content="#0a84ff" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:locale" content={locale} />
    <meta property="og:locale:alternate" content={alternateLocale} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:secure_url" content={imageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:alt" content={pageTitle} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{pageTitle}</title>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SG22N163D3"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-SG22N163D3');
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script is:inline>
      (() => {
        try {
          const langKey = 'ai-landscape-lang';
          if (!localStorage.getItem(langKey)) {
            const p = location.pathname.replace(/\/+$/, '');
            if (p === '') {
              const nav = (navigator.language || '').toLowerCase();
              if (nav.startsWith('zh')) {
                localStorage.setItem(langKey, 'zh');
                location.replace('/zh/');
                return;
              }
              localStorage.setItem(langKey, 'en');
            }
          }
        } catch {}
      })();
    </script>
    <script is:inline>
      (() => {
        try {
          const key = 'ai-landscape-theme';
          const stored = localStorage.getItem(key);
          const preference = stored === 'light' || stored === 'dark' || stored === 'system' ? stored : 'system';
          const resolved = preference === 'system'
            ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
            : preference;
          document.documentElement.dataset.themePreference = preference;
          document.documentElement.dataset.theme = resolved;
        } catch {
          document.documentElement.dataset.themePreference = 'system';
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
    <script is:inline define:vars={{
      scoreApiBase: SITE.scoreApiBase,
      scoreLabels: copy.scoreLabels,
      scoreLoading: copy.scoreLoading,
      scoreUnavailable: copy.scoreUnavailable,
      pageLang: lang,
    }}>
      (() => {
        const normalizeRepo = (value) => String(value || '').trim().toLowerCase();
        const cache = new Map();
        const batchSize = 40;

        const labelFor = (score) => {
          if (!Number.isFinite(score)) return scoreUnavailable;
          if (score >= 90) return scoreLabels.mustWatch;
          if (score >= 80) return scoreLabels.strongRecommendation;
          if (score >= 70) return scoreLabels.worthTrying;
          if (score >= 60) return scoreLabels.monitorProgress;
          return scoreLabels.exploreCarefully;
        };

        const formatScore = (value) => (Number.isFinite(value) ? String(Math.round(value)) : '--');

        async function fetchBatch(repos, locale) {
          if (repos.length === 0) return [];
          const url = new URL('/api/health', scoreApiBase);
          url.searchParams.set('repos', repos.join(','));
          url.searchParams.set('locale', locale);
          const response = await fetch(url.toString());
          if (!response.ok) {
            throw new Error(`Score API request failed with ${response.status}`);
          }
          const payload = await response.json();
          return Array.isArray(payload.projects) ? payload.projects : [];
        }

        async function fetchScores(repos, locale = pageLang) {
          const normalized = Array.from(new Set(repos.map(normalizeRepo).filter(Boolean)));
          const missing = normalized.filter((repo) => !cache.has(repo));

          for (let index = 0; index < missing.length; index += batchSize) {
            const batch = missing.slice(index, index + batchSize);
            const projects = await fetchBatch(batch, locale);
            const seen = new Set();

            projects.forEach((project) => {
              const repo = normalizeRepo(project.repo);
              seen.add(repo);
              cache.set(repo, project);
            });

            batch.forEach((repo) => {
              if (!seen.has(repo)) cache.set(repo, null);
            });
          }

          return cache;
        }

        function getCachedScore(repo) {
          const entry = cache.get(normalizeRepo(repo));
          return entry?.scores || null;
        }

        function getProjectData(repo) {
          return cache.get(normalizeRepo(repo)) || null;
        }

        function computeStatus(project) {
          if (!project) return 'unknown';
          if (project.tags?.isArchived) return 'archived';
          if (project.metrics?.daysSinceLastCommit > 180) return 'inactive';
          const created = project.metrics?.createdAt;
          if (created && (Date.now() - new Date(created).getTime()) < 30 * 86400000) return 'newlyAdded';
          if (project.scores?.health >= 80) return 'recommended';
          if (project.scores?.health >= 60) return 'worthWatching';
          return 'worthWatching';
        }

        function getProjectStatus(repo) {
          const project = getProjectData(repo);
          return computeStatus(project);
        }

        function getProjectMetrics(repo) {
          const project = getProjectData(repo);
          return project?.metrics || null;
        }

        function applyScoreToElement(element) {
          const score = getCachedScore(element.dataset.scoreRepo);
          const health = score?.health;
          const stateLabel = Number.isFinite(health) ? labelFor(health) : scoreUnavailable;

          const selectNode = (selector) => (element.matches(selector) ? element : element.querySelector(selector));

          const valueNode = selectNode('[data-score-value]');
          if (valueNode) valueNode.textContent = formatScore(health);

          const labelNode = selectNode('[data-score-label]');
          if (labelNode) labelNode.textContent = stateLabel;

          const meterNode = selectNode('[data-score-meter]');
          if (meterNode) meterNode.value = Number.isFinite(health) ? Math.round(health) : 0;

          const healthNode = selectNode('[data-score-health]');
          if (healthNode) healthNode.textContent = formatScore(score?.health);

          const activityNode = selectNode('[data-score-activity]');
          if (activityNode) activityNode.textContent = formatScore(score?.activity);

          const communityNode = selectNode('[data-score-community]');
          if (communityNode) communityNode.textContent = formatScore(score?.community);

          const qualityNode = selectNode('[data-score-quality]');
          if (qualityNode) qualityNode.textContent = formatScore(score?.quality);

          const sustainabilityNode = selectNode('[data-score-sustainability]');
          if (sustainabilityNode) sustainabilityNode.textContent = formatScore(score?.sustainability);
        }

        async function hydrateScores(scope = document, locale = pageLang) {
          const elements = Array.from(scope.querySelectorAll('[data-score-repo]'));
          const repos = elements.map((element) => element.dataset.scoreRepo).filter(Boolean);

          try {
            await fetchScores(repos, locale);
          } catch {
            elements.forEach((element) => {
              const labelNode = element.querySelector('[data-score-label]');
              if (labelNode) labelNode.textContent = scoreUnavailable;
            });
          }

          elements.forEach((element) => applyScoreToElement(element));
          return cache;
        }

        window.aiLandscapeScores = {
          fetchScores,
          getCachedScore,
          getProjectData,
          getProjectMetrics,
          getProjectStatus,
          computeStatus,
          hydrateScores,
          scoreLabel: labelFor,
        };
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__bar">
        <a class="brand" href={localizedPath('/', lang)}>
          <span class="brand-mark">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path class="brand-mark__path" d="M7.5 25.5L18 8.8l10.5 16.7" />
              <path class="brand-mark__bar" d="M12.2 25.5h11.6" />
              <circle class="brand-mark__node" cx="18" cy="19.5" r="3.2" />
            </svg>
          </span>
          <span class="brand-wordmark">
            <strong aria-label={SITE.title}>{SITE.title}</strong>
          </span>
        </a>
        <button
          class="site-header__menu-toggle"
          type="button"
          data-nav-toggle
          aria-expanded="false"
          aria-controls="site-primary-nav"
          aria-label={lang === 'zh' ? '切换导航菜单' : 'Toggle navigation menu'}
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h16" />
          </svg>
        </button>
      </div>
      <nav class="site-nav" id="site-primary-nav" aria-label="Primary">
        <div class="site-nav__links">
          <button class="site-nav__link" type="button" data-nav-search aria-label={copy.search}>
            <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span>{copy.search}</span>
          </button>
          <a class="site-nav__link" href={localizedPath('/methodology/', lang)}>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 19h16"/><path d="M7 16V8M12 16V5M17 16v-6"/></svg>
            <span>{copy.navMethodology}</span>
          </a>
          <a class="site-nav__link" href={localizedPath('/tomb/', lang)}>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 21h18"/><path d="M5 21V7l8-4 8 4v14"/><path d="M9 21v-4a3 3 0 0 1 6 0v4"/><path d="M10 10h4"/></svg>
            <span>{copy.navTomb}</span>
          </a>
          <a class="site-nav__link" href={localizedPath('/about/', lang)}>
            <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 10v5"/><path d="M12 7h.01"/></svg>
            <span>{copy.navAbout}</span>
          </a>
        </div>
        <div class="site-nav__actions">
          <div class="language-menu" data-language-menu>
            <button
              class="language-menu__trigger"
              type="button"
              aria-haspopup="menu"
              aria-label={lang === 'zh' ? '选择语言' : 'Choose language'}
