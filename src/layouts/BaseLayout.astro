              <svg class="language-menu__caret" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M7 10l5 5 5-5" />
              </svg>
            </button>
            <div class="language-menu__list" role="menu" aria-label={lang === 'zh' ? '语言列表' : 'Language list'}>
              {languageOptions.map((option) => (
                <a
                  class:list={["language-menu__option", option.code === lang && 'is-current']}
                  href={option.href}
                  role="menuitem"
                  aria-current={option.code === lang ? 'page' : undefined}
                >
                  <span>{option.label}</span>
                  {option.code === lang ? (
                    <svg class="language-menu__check" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M5 12l5 5L20 7" />
                    </svg>
                  ) : null}
                </a>
              ))}
            </div>
          </div>
          <div class="theme-menu" data-theme-menu>
            <button
              class="theme-switch"
              type="button"
              data-theme-toggle
              aria-label={copy.themeToggleAria}
              aria-expanded="false"
              aria-controls="theme-menu-list"
            >
              <svg class="theme-switch-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 3v2M12 19v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M3 12h2M19 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4M12 8a4 4 0 100 8 4 4 0 000-8z"/>
              </svg>
              <svg class="theme-switch-caret" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M7 10l5 5 5-5"/>
              </svg>
            </button>
            <div class="theme-menu-list" id="theme-menu-list" role="menu" hidden>
              <button type="button" role="menuitemradio" data-theme-option="system" aria-checked="false">
                <svg class="theme-option-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M4 5h16v10H4zM8 19h8M10 15v4M14 15v4"/>
                </svg>
                <span>{copy.themeSystem}</span>
              </button>
              <button type="button" role="menuitemradio" data-theme-option="light" aria-checked="false">
                <svg class="theme-option-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 3v2M12 19v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M3 12h2M19 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4M12 8a4 4 0 100 8 4 4 0 000-8z"/>
                </svg>
                <span>{copy.themeLight}</span>
              </button>
              <button type="button" role="menuitemradio" data-theme-option="dark" aria-checked="false">
                <svg class="theme-option-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M21 12.8A9 9 0 1111.2 3a7 7 0 009.8 9.8z"/>
                </svg>
                <span>{copy.themeDark}</span>
              </button>
            </div>
          </div>
          <a class="github-star" href={SITE.starRepo} target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            <span class="action-label">{copy.navGithub}</span>
          </a>
        </div>
      </nav>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-top">
          <div class="footer-brand">
            <a class="footer-brand__link" href={localizedPath('/', lang)}>
              <svg class="footer-brand__icon" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M7.5 25.5L18 8.8l10.5 16.7" />
                <path d="M12.2 25.5h11.6" />
                <circle cx="18" cy="19.5" r="3.2" />
              </svg>
              <span class="footer-brand__title">{copy.footerTitle}</span>
            </a>
            <p class="footer-brand__desc">{copy.footerDescription}</p>
          </div>
          <div class="footer-nav">
            <div class="footer-nav__group">
              <h3 class="footer-nav__heading">{copy.footerResources}</h3>
              <ul class="footer-nav__list">
                <li>
                  <a href={footerBlogUrl} target="_blank" rel="noopener noreferrer">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 19.5h14"/><path d="M7 16.5V5.5a2 2 0 0 1 2-2h8v13"/><path d="M7 7.5h10"/><path d="M10 11.5h7"/></svg>
                    <span>{copy.footerBlog}</span>
                  </a>
                </li>
                <li>
                  <a href={footerBookUrl} target="_blank" rel="noopener noreferrer">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H20v16H6.5A2.5 2.5 0 0 0 4 21.5z"/><path d="M8 7h8"/><path d="M8 11h8"/></svg>
                    <span>{copy.footerBook}</span>
                  </a>
                </li>
                <li>
                  <a href={localizedPath('/about/', lang)}>
                    <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 10v5"/><path d="M12 7h.01"/></svg>
                    <span>{copy.footerAbout}</span>
                  </a>
                </li>
              </ul>
            </div>
            <div class="footer-nav__group">
              <h3 class="footer-nav__heading">{copy.footerCommunity}</h3>
              <ul class="footer-nav__list">
                <li>
                  <a class="footer-link--github" href={SITE.starRepo} target="_blank" rel="noopener noreferrer">
                    <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                    <span>{copy.navGithub}</span>
                  </a>
                </li>
                <li>
                  <a href={SITE.issueNew} target="_blank" rel="noopener noreferrer">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12h14"/><path d="M4 4h16v16H4z"/></svg>
                    <span>{copy.footerSubmit}</span>
                  </a>
                </li>
                <li>
                  <a href={SITE.mainSite} target="_blank" rel="noopener noreferrer">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    <span>{copy.footerMainSite}</span>
                  </a>
                </li>
              </ul>
            </div>
          </div>
        </div>
        <div class="footer-bottom">
          <span class="footer-bottom__copy">{footerCopyright}</span>
        </div>
      </div>
    </footer>
    <script is:inline define:vars={{
      themeLabels: {
        system: copy.themeSystem,
        dark: copy.themeDark,
        light: copy.themeLight,
      },
      toggleAria: copy.themeToggleAria,
    }}>
      (() => {
        const key = 'ai-landscape-theme';
        const root = document.documentElement;
        const menuRoot = document.querySelector('[data-theme-menu]');
        const button = document.querySelector('[data-theme-toggle]');
        const menu = document.getElementById('theme-menu-list');
        const options = Array.from(document.querySelectorAll('[data-theme-option]'));
        const header = document.querySelector('.site-header');
        const navToggle = document.querySelector('[data-nav-toggle]');
        const media = window.matchMedia('(prefers-color-scheme: dark)');
        const order = ['system', 'dark', 'light'];

        const normalize = (value) => (order.includes(value) ? value : 'system');
        const resolve = (preference) =>
          preference === 'system' ? (media.matches ? 'dark' : 'light') : preference;

        const setNavOpen = (open) => {
          if (!header || !navToggle) return;
          header.classList.toggle('is-nav-open', open);
          navToggle.setAttribute('aria-expanded', String(open));
        };

        const setMenuOpen = (open) => {
          if (!button || !menu) return;
          button.setAttribute('aria-expanded', String(open));
          menu.hidden = !open;
        };

        const updateOptionState = (preference) => {
          options.forEach((node) => {
            const checked = node.dataset.themeOption === preference;
            node.setAttribute('aria-checked', String(checked));
          });
        };

        const render = (preference) => {
          const resolved = resolve(preference);
          root.dataset.themePreference = preference;
          root.dataset.theme = resolved;
          if (button) button.setAttribute('aria-label', `${toggleAria}: ${themeLabels[preference]}`);
          updateOptionState(preference);
        };

        const apply = (preference, persist = true) => {
          const next = normalize(preference);
          if (persist) localStorage.setItem(key, next);
          render(next);
        };

        const current = normalize(localStorage.getItem(key));
        apply(current, false);

        if (button && menu) {
          button.addEventListener('click', (event) => {
            event.stopPropagation();
            const expanded = button.getAttribute('aria-expanded') === 'true';
            setMenuOpen(!expanded);
          });
        }

        options.forEach((node) => {
          node.addEventListener('click', (event) => {
            event.stopPropagation();
            const preference = normalize(node.dataset.themeOption);
            apply(preference, true);
            setMenuOpen(false);
          });
        });

        if (navToggle) {
          navToggle.addEventListener('click', (event) => {
            event.stopPropagation();
            const expanded = navToggle.getAttribute('aria-expanded') === 'true';
            setNavOpen(!expanded);
          });
        }

        document.addEventListener('click', (event) => {
          if (header && !header.contains(event.target)) {
            setNavOpen(false);
          }
          if (menuRoot && !menuRoot.contains(event.target)) {
            setMenuOpen(false);
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            setNavOpen(false);
            setMenuOpen(false);
          }
        });

        if (menu) {
          menu.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
              setMenuOpen(false);
            }
          });
        }

        media.addEventListener('change', () => {
          if (normalize(root.dataset.themePreference) === 'system') {
            render('system');
          }
        });

        window.matchMedia('(min-width: 721px)').addEventListener('change', (event) => {
          if (event.matches) {
            setNavOpen(false);
          }
        });

        window.aiLandscapeScores?.hydrateScores(document, root.lang?.startsWith('zh') ? 'zh' : 'en').then(() => {
          window.dispatchEvent(new CustomEvent('ai-landscape:scores-ready'));
        }).catch(() => {
          window.dispatchEvent(new CustomEvent('ai-landscape:scores-ready'));
        });

      })();

      // Nav search button & Cmd+K — open search modal
      function openSearch() {
        document.dispatchEvent(new CustomEvent('open-search-modal'));
      }
      document.querySelectorAll('[data-nav-search]').forEach((btn) => {
        btn.addEventListener('click', (event) => {
          event.preventDefault();
          event.stopPropagation();
          openSearch();
          const header = document.querySelector('.site-header');
          const navToggle = document.querySelector('[data-nav-toggle]');
          header?.classList.remove('is-nav-open');
          navToggle?.setAttribute('aria-expanded', 'false');
        });
      });
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          openSearch();
        }
      });
    </script>
    {!isHomePage && <SearchModal lang={lang} />}
  </body>
</html>
