---
import ProjectDetail from '../../../components/ProjectDetail.astro';
import { getProjects } from '../../../lib/landscape.mjs';

export async function getStaticPaths() {
  return getProjects().map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const allProjects = getProjects().filter(p => p.slug !== project.slug);
---

<ProjectDetail project={project} allProjects={allProjects} lang="zh" />