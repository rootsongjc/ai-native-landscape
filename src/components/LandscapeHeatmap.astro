---
import {
  categoryName,
  getLandscape,
  localizedPath,
  projectIconUrl,
  projectDescription,
  scoreLabel,
  SCORE_TIERS,
  ui,
} from '../lib/landscape.mjs';

const { lang = 'en' } = Astro.props;
const copy = ui(lang);
const landscape = getLandscape();
const categories = landscape.categories
  .filter((cat) => (landscape.byCategory[cat.key] || []).length > 0)
  .sort((a, b) => (landscape.byCategory[b.key] || []).length - (landscape.byCategory[a.key] || []).length);

const tierMeta = SCORE_TIERS;
---

<div class="heatmap" id="landscape-heatmap" data-heatmap>
  <div class="heatmap__header">
    <div class="heatmap__corner"></div>
    {tierMeta.map((tier) => (
      <div class="heatmap__col-label" data-tier={tier.key}>
        <span class="heatmap__col-dot" style={`background:${tier.color}`}></span>
        {scoreLabel(tier.min + 5, lang)}
      </div>
    ))}
  </div>

  {categories.map((cat) => {
    const projects = landscape.byCategory[cat.key] || [];
    const catName = categoryName(cat, lang);
    return (
      <div class="heatmap__row" data-category={cat.key}>
        <div class="heatmap__row-label">{catName}</div>
        {tierMeta.map((tier) => (
          <div class="heatmap__cell" data-tier={tier.key}></div>
        ))}
        <div class="heatmap__staging" data-staging hidden>
          {projects.slice(0, 50).map((p) => {
            const icon = projectIconUrl(p, 64);
            const href = localizedPath(`/projects/${p.slug}/`, lang);
            const desc = projectDescription(p, lang);
            return (
              <a
                class="heatmap__chip"
                href={href}
                data-score-repo={p.repoSlug || ''}
                data-card-name={p.name}
                title={`${p.name}${desc ? ' – ' + desc : ''}`}
              >
                {icon ? (
                  <img src={icon} alt="" loading="lazy" decoding="async" onerror="this.hidden=true;this.nextElementSibling.hidden=false" />
                ) : null}
                <span class="heatmap__chip-initial" hidden={Boolean(icon)}>
                  {p.name.slice(0, 1).toUpperCase()}
                </span>
              </a>
            );
          })}
        </div>
      </div>
    );
  })}

  <div class="heatmap__legend">
    {tierMeta.map((tier) => (
      <span class="heatmap__legend-item">
        <span class="heatmap__legend-dot" style={`background:${tier.color}`}></span>
        {scoreLabel(tier.min + 5, lang)}
      </span>
    ))}
  </div>
</div>

<style>
  .heatmap {
    display: grid;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
  }

  .heatmap__header {
    display: grid;
    grid-template-columns: 160px repeat(5, 1fr);
    border-bottom: 2px solid var(--border);
    background: var(--surface-soft);
  }

  .heatmap__corner { border-right: 1px solid var(--border); padding: 10px; }

  .heatmap__col-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px 6px;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text);
    text-align: center;
    border-right: 1px solid var(--border);
    white-space: nowrap;
  }
  .heatmap__col-label:last-child { border-right: none; }

  .heatmap__col-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .heatmap__row {
    display: grid;
    grid-template-columns: 160px repeat(5, 1fr);
    border-bottom: 1px solid var(--border);
    min-height: 48px;
    position: relative;
  }
  .heatmap__row:last-of-type { border-bottom: none; }

  .heatmap__row-label {
    display: flex;
    align-items: center;
    padding: 8px 12px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text);
    border-right: 1px solid var(--border);
    background: var(--surface-soft);
  }

  .heatmap__cell {
    padding: 6px;
    border-right: 1px solid var(--border);
    min-height: 48px;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    align-items: center;
    align-content: flex-start;
    transition: background 0.2s;
  }
  .heatmap__cell:last-of-type { border-right: none; }

  .heatmap__cell[data-tier="tier90"] { background: rgba(34, 197, 94, 0.06); }
  .heatmap__cell[data-tier="tier80"] { background: rgba(132, 204, 22, 0.06); }
  .heatmap__cell[data-tier="tier70"] { background: rgba(234, 179, 8, 0.06); }
  .heatmap__cell[data-tier="tier60"] { background: rgba(249, 115, 22, 0.06); }
  .heatmap__cell[data-tier="tierBelow"] { background: rgba(239, 68, 68, 0.04); }

  html[data-theme='dark'] .heatmap__cell[data-tier="tier90"] { background: rgba(34, 197, 94, 0.1); }
  html[data-theme='dark'] .heatmap__cell[data-tier="tier80"] { background: rgba(132, 204, 22, 0.1); }
  html[data-theme='dark'] .heatmap__cell[data-tier="tier70"] { background: rgba(234, 179, 8, 0.1); }
  html[data-theme='dark'] .heatmap__cell[data-tier="tier60"] { background: rgba(249, 115, 22, 0.1); }
  html[data-theme='dark'] .heatmap__cell[data-tier="tierBelow"] { background: rgba(239, 68, 68, 0.08); }

  .heatmap__staging { display: none; }

  .heatmap__chip {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: #fff;
    border: 1px solid var(--border);
    overflow: hidden;
    transition: all 0.15s;
    text-decoration: none;
    flex-shrink: 0;
  }
  .heatmap__chip:hover {
    transform: scale(1.25);
    z-index: 5;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    border-color: var(--accent);
  }
  .heatmap__chip img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 7px;
    display: block;
  }
  .heatmap__chip-initial {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--muted);
  }

  .heatmap__cell--loading {
    justify-content: center;
  }
  .heatmap__cell--loading::after {
    content: '···';
    color: var(--muted);
    font-size: 0.8rem;
  }

  .heatmap__legend {
    display: flex;
    gap: 16px;
    padding: 10px 16px;
    background: var(--surface-soft);
    border-top: 1px solid var(--border);
    font-size: 0.75rem;
    color: var(--muted);
  }
  .heatmap__legend-item {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .heatmap__legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  @media (max-width: 1023px) {
    .heatmap__header,
    .heatmap__row {
      grid-template-columns: 120px repeat(5, 1fr);
    }
    .heatmap__chip { width: 26px; height: 26px; border-radius: 7px; }
    .heatmap__chip img { border-radius: 6px; }
    .heatmap__col-label { font-size: 0.65rem; padding: 6px 2px; }
    .heatmap__row-label { font-size: 0.72rem; padding: 6px 8px; }
  }

  @media (max-width: 767px) {
    .heatmap { display: none; }
  }
</style>
