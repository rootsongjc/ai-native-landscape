    }
    .detail-highlights .hero-metric__label svg {
      width: 14px;
      height: 14px;
      flex-basis: 14px;
    }
    .detail-highlights .hero-metric strong {
      grid-column: auto;
      display: inline-block;
      max-width: 8rem;
      font-size: 0.76rem;
      line-height: 1.1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .detail-hero__side {
      gap: 8px;
      padding-top: 10px;
    }
    .detail-score-panel {
      padding: 7px 8px;
    }
    .detail-score-panel__eyebrow {
