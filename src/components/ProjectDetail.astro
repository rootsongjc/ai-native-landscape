<script>
  const repoMetadataRequests = new Map();
  const repoLanguagesRequests = new Map();

  function formatNum(n) {
    if (n == null || !Number.isFinite(n)) return '--';
    if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return (n / 1000).toFixed(1) + 'k';
    return String(n);
  }

  function relativeTime(dateStr) {
    if (!dateStr) return '--';
    const diff = Date.now() - new Date(dateStr).getTime();
    const days = Math.floor(diff / 86400000);
    if (days === 0) {
      const hours = Math.floor(diff / 3600000);
      if (hours === 0) return document.documentElement.lang?.startsWith('zh') ? '刚刚' : 'just now';
      return hours + (document.documentElement.lang?.startsWith('zh') ? '小时前' : 'h ago');
    }
    if (days === 1) return document.documentElement.lang?.startsWith('zh') ? '昨天' : 'yesterday';
    return days + (document.documentElement.lang?.startsWith('zh') ? '天前' : 'd ago');
  }

  function formatDate(dateStr) {
    if (!dateStr) return '--';
    return new Date(dateStr).toISOString().slice(0, 10);
  }

  function formatLicense(license) {
    if (!license) return '';
    if (license.spdx_id && license.spdx_id !== 'NOASSERTION') return license.spdx_id;
    return license.name || '';
  }

  async function fetchGitHubRepo(repo) {
    if (!repo) return null;
    if (!repoMetadataRequests.has(repo)) {
      repoMetadataRequests.set(repo, (async () => {
        try {
          const response = await fetch(`https://api.github.com/repos/${repo}`);
          if (!response.ok) return null;
          return await response.json();
        } catch {
          return null;
        }
      })());
    }

    return repoMetadataRequests.get(repo);
  }

  async function fetchGitHubLanguages(repo) {
    if (!repo) return null;
    if (!repoLanguagesRequests.has(repo)) {
      repoLanguagesRequests.set(repo, (async () => {
        try {
          const response = await fetch(`https://api.github.com/repos/${repo}/languages`);
          if (!response.ok) return null;
          return await response.json();
        } catch {
          return null;
        }
      })());
    }

    return repoLanguagesRequests.get(repo);
  }

  function pickPrimaryLanguage(languages, fallback = '') {
    if (languages && typeof languages === 'object') {
      let maxBytes = -1;
      let primary = '';
      Object.entries(languages).forEach(([name, bytes]) => {
        if (typeof bytes !== 'number' || !Number.isFinite(bytes)) return;
        if (bytes > maxBytes) {
          maxBytes = bytes;
          primary = name;
        }
      });
      if (primary) return primary;
    }
    return fallback || '';
  }

  async function hydrateGitHubMetadata(repo) {
    if (!repo) return;

    const licenseNodes = document.querySelectorAll('[data-metrics-license]');
    const languageNodes = document.querySelectorAll('[data-metrics-language]');
    const languageCards = document.querySelectorAll('[data-github-language-card]');
    if (
      licenseNodes.length === 0 &&
      languageNodes.length === 0
    ) {
      return;
    }

    const [payload, languagesPayload] = await Promise.all([
      fetchGitHubRepo(repo),
      fetchGitHubLanguages(repo),
    ]);
    if (!payload) return;

    const license = formatLicense(payload.license);
    if (license) {
      licenseNodes.forEach((el) => {
        el.textContent = license;
      });
    }

    const language = pickPrimaryLanguage(languagesPayload, payload.language || '');
    languageCards.forEach((el) => {
      el.hidden = !language;
    });
    if (language) {
      languageNodes.forEach((el) => {
        el.textContent = language;
      });
    }

    try {
      // License is supplemental metadata; keep the curated fallback if GitHub is unavailable.
    } catch {}
  }

  function hydrateDetail() {
    if (!window.aiLandscapeScores) return;
    const heroBar = document.querySelector('.detail-score');
    if (!heroBar?.dataset.scoreRepo) return;

    const repo = heroBar.dataset.scoreRepo;
    const data = window.aiLandscapeScores.getProjectData?.(repo);
    const scores = data?.scores;
    const metrics = data?.metrics;

    // Update score ring arc
    const scoreValueEl = document.querySelector('[data-score-value]');
    const scoreArcEl = document.querySelector('[data-score-arc]');
    if (scores && scoreValueEl && scoreArcEl) {
      const overall = Math.round((scores.activity + scores.community + scores.quality + scores.sustainability) / 4);
      scoreValueEl.textContent = overall;
      const circumference = 2 * Math.PI * 26; // r=26
      const filled = (overall / 100) * circumference;
      scoreArcEl.style.strokeDasharray = `${filled} ${circumference}`;
      // Update popover total
      document.querySelectorAll('[data-score-value-total]').forEach(el => el.textContent = overall);
    }

    document.querySelectorAll('[data-score-dimension]').forEach(el => {
      const dim = el.dataset.scoreDimension;
      if (!scores || scores[dim] == null) return;
      el.style.width = Math.round(scores[dim]) + '%';
    });
    document.querySelectorAll('[data-score-activity]').forEach(el => el.textContent = scores ? Math.round(scores.activity) : '--');
    document.querySelectorAll('[data-score-community]').forEach(el => el.textContent = scores ? Math.round(scores.community) : '--');
    document.querySelectorAll('[data-score-quality]').forEach(el => el.textContent = scores ? Math.round(scores.quality) : '--');
    document.querySelectorAll('[data-score-sustainability]').forEach(el => el.textContent = scores ? Math.round(scores.sustainability) : '--');

    if (metrics) {
      document.querySelectorAll('[data-metric-stars]').forEach(el => el.textContent = formatNum(metrics.stars));
      document.querySelectorAll('[data-metric-forks]').forEach(el => el.textContent = formatNum(metrics.forks));
      document.querySelectorAll('[data-metric-issues]').forEach(el => el.textContent = formatNum(metrics.openIssues));
      document.querySelectorAll('[data-metric-contributors]').forEach(el => el.textContent = formatNum(metrics.contributors));
      document.querySelectorAll('[data-metric-last-commit]').forEach(el => el.textContent = relativeTime(metrics.lastCommitAt));
      document.querySelectorAll('[data-metric-commits-year]').forEach(el => el.textContent = formatNum(metrics.commitsLastYear));
      document.querySelectorAll('[data-metric-created]').forEach(el => el.textContent = formatDate(metrics.createdAt));
      document.querySelectorAll('[data-metrics-stars]').forEach(el => el.textContent = formatNum(metrics.stars));
      document.querySelectorAll('[data-metrics-forks]').forEach(el => el.textContent = formatNum(metrics.forks));
      document.querySelectorAll('[data-metrics-issues]').forEach(el => el.textContent = formatNum(metrics.openIssues));
      document.querySelectorAll('[data-metrics-contributors]').forEach(el => el.textContent = formatNum(metrics.contributors));
      document.querySelectorAll('[data-metrics-created]').forEach(el => el.textContent = formatDate(metrics.createdAt));
    }

    hydrateGitHubMetadata(repo);
  }

  window.addEventListener('ai-landscape:scores-ready', hydrateDetail);
  const check = setInterval(() => {
    const heroBar = document.querySelector('.detail-score');
    if (heroBar?.dataset.scoreRepo && window.aiLandscapeScores?.getProjectData?.(heroBar.dataset.scoreRepo)) {
      hydrateDetail();
      clearInterval(check);
    }
  }, 500);
  setTimeout(() => clearInterval(check), 10000);

  // Score popover toggle — position relative to button
  document.addEventListener('click', (e) => {
    const toggle = e.target.closest('[data-score-info-toggle]');
    if (toggle) {
      e.stopPropagation();
      const popover = document.querySelector('[data-score-popover]');
      if (!popover) return;
      const isVisible = popover.classList.contains('score-popover--visible');
      // Close first
      popover.classList.remove('score-popover--visible');
      if (!isVisible) {
        // Temporarily show off-screen to measure height
        popover.style.visibility = 'hidden';
        popover.style.display = 'flex';
        popover.style.top = '-9999px';
        popover.style.left = '-9999px';
        const popH = popover.offsetHeight;
        const popW = 260; // fixed width
        popover.style.display = '';
        popover.style.visibility = '';

        const rect = toggle.getBoundingClientRect();
        const gap = 8;
        // Prefer right-aligned with button
        let top = rect.bottom + gap;
        let left = rect.right - popW;
        // Flip above if overflows bottom
        if (top + popH > window.innerHeight) top = rect.top - popH - gap;
        // Clamp to viewport
        if (left < 8) left = 8;
        if (left + popW > window.innerWidth - 8) left = window.innerWidth - popW - 8;
        if (top < 8) top = 8;
        popover.style.top = top + 'px';
        popover.style.left = left + 'px';
        popover.classList.add('score-popover--visible');
      }
      return;
    }
    // Close on outside click
    document.querySelectorAll('.score-popover--visible').forEach(p => p.classList.remove('score-popover--visible'));
  });

  // ── Share Card Logic ──
  (function() {
    const section = document.querySelector('[data-share-section]');
    if (!section) return;

    const generateBtn = section.querySelector('[data-share-generate]');
    const copyBtn = section.querySelector('[data-share-copy]');
    const xLink = section.querySelector('[data-share-x]');
    const linkedInLink = section.querySelector('[data-share-linkedin]');
    const template = document.querySelector('[data-share-card-template]');
    if (!template) return;

    const lang = document.documentElement.lang?.startsWith('zh') ? 'zh' : 'en';
    const copy = {
      generating: lang === 'zh' ? '生成中...' : 'Generating...',
      linkCopied: lang === 'zh' ? '链接已复制' : 'Link Copied',
      generateFailed: lang === 'zh' ? '生成失败，请重试' : 'Generation failed, please retry',
    };

    const projectName = document.querySelector('.detail-hero__info h1')?.textContent?.trim() || '';
    const projectDesc = document.querySelector('.detail-desc')?.textContent?.trim() || '';
    const projectUrl = window.location.href.split('?')[0].split('#')[0];

    // Social share URLs
    if (xLink) {
      const text = encodeURIComponent(`${projectName} — ${projectDesc}`);
      xLink.href = `https://twitter.com/intent/tweet?text=${text}&url=${encodeURIComponent(projectUrl)}`;
    }
    if (linkedInLink) {
      linkedInLink.href = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(projectUrl)}`;
    }

    // Copy link
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(projectUrl).then(() => {
          showToast(copy.linkCopied);
        }).catch(() => {
          // Fallback
          const ta = document.createElement('textarea');
          ta.value = projectUrl;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          showToast(copy.linkCopied);
        });
      });
    }

    // Generate share card PNG
    if (generateBtn) {
      generateBtn.addEventListener('click', async () => {
        const originalText = generateBtn.querySelector('span')?.textContent;
        if (generateBtn.querySelector('span')) generateBtn.querySelector('span').textContent = copy.generating;
        generateBtn.disabled = true;

        try {
          // Fill card data from page
          await fillCardData();
          // Generate QR code
          await generateQRCode();
          // Wait for images to load
          await waitForImages();

          const html2canvas = (await import('html2canvas')).default;
          const cardEl = template.querySelector('.sc');
          const canvas = await html2canvas(cardEl, {
            width: 1200,
            height: 630,
            scale: 2,
            useCORS: true,
            allowTaint: true,
            backgroundColor: null,
            logging: false,
          });

          // Download
          canvas.toBlob(blob => {
            if (!blob) { showToast(copy.generateFailed); return; }
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `${projectName.replace(/[^a-zA-Z0-9一-鿿]/g, '-').replace(/-+/g, '-')}-share.png`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
          }, 'image/png');
        } catch (err) {
          console.error('Share card generation failed:', err);
          showToast(copy.generateFailed);
        } finally {
          if (generateBtn.querySelector('span')) generateBtn.querySelector('span').textContent = originalText;
          generateBtn.disabled = false;
        }
      });
    }

    async function fillCardData() {
      const heroBar = document.querySelector('.detail-score');
      const repo = heroBar?.dataset.scoreRepo;
      const data = repo ? window.aiLandscapeScores?.getProjectData?.(repo) : null;
      const scores = data?.scores;
      const metrics = data?.metrics;

      // Scores
      if (scores) {
        const overall = Math.round((scores.activity + scores.community + scores.quality + scores.sustainability) / 4);
        const healthEl = template.querySelector('[data-sc-health]');
        const healthLabelEl = template.querySelector('[data-sc-health-label]');
        if (healthEl) healthEl.textContent = overall;
        if (healthLabelEl) {
          healthLabelEl.textContent = overall >= 80
            ? (lang === 'zh' ? '优秀' : 'Excellent')
            : overall >= 60
              ? (lang === 'zh' ? '良好' : 'Good')
              : overall >= 40
                ? (lang === 'zh' ? '一般' : 'Fair')
                : (lang === 'zh' ? '待改进' : 'Needs Work');
          healthLabelEl.style.color = overall >= 80 ? '#34d399' : overall >= 60 ? '#60a5fa' : overall >= 40 ? '#fbbf24' : '#f87171';
        }

        const dims = ['activity', 'community', 'quality', 'sustainability'];
        dims.forEach(dim => {
          const val = Math.round(scores[dim]);
          const valEl = template.querySelector(`[data-sc-${dim}]`);
          const barEl = template.querySelector(`[data-sc-bar-${dim}]`);
          if (valEl) valEl.textContent = val;
          if (barEl) barEl.style.width = val + '%';
        });
      }

      // Metrics
      if (metrics) {
        const setIfExists = (sel, val) => { const el = template.querySelector(sel); if (el) el.textContent = val; };
        setIfExists('[data-sc-stars]', formatNum(metrics.stars));
        setIfExists('[data-sc-forks]', formatNum(metrics.forks));
        setIfExists('[data-sc-issues]', formatNum(metrics.openIssues));
        setIfExists('[data-sc-contributors]', formatNum(metrics.contributors));
      }
    }

    async function generateQRCode() {
      const canvas = template.querySelector('[data-sc-qrcode]');
      if (!canvas) return;
      try {
        const QRCode = (await import('qrcode')).default;
        await QRCode.toCanvas(canvas, projectUrl, {
          width: 80,
          margin: 1,
          color: { dark: '#0f172a', light: '#ffffff' },
          errorCorrectionLevel: 'M',
        });
      } catch (err) {
        console.error('QR generation failed:', err);
      }
    }

    async function waitForImages() {
      // Draw logo on canvas via CORS proxy
      const logoCanvas = template.querySelector('[data-sc-logo-canvas]');
      if (logoCanvas) {
        const ctx = logoCanvas.getContext('2d');
        // Use high-res 400px source image from data attribute
        const logoUrl = logoCanvas.dataset.scLogoSrc || '';
        let drawn = false;

        if (logoUrl) {
          const urls = [logoUrl];
          if (logoUrl.includes('github')) {
            urls.push(`https://images.weserv.nl/?url=${encodeURIComponent(logoUrl)}&default=1`);
          }

          for (const url of urls) {
            try {
              const resp = await fetch(url, { mode: 'cors', credentials: 'omit' });
              if (!resp.ok) continue;
              const blob = await resp.blob();
              const img = await createImageBitmap(blob);
              ctx.save();
              ctx.beginPath();
              ctx.roundRect(0, 0, 192, 192, 48);
              ctx.clip();
              ctx.drawImage(img, 0, 0, 192, 192);
              ctx.restore();
              drawn = true;
              break;
            } catch { continue; }
          }
        }

        if (!drawn) {
          const gradient = ctx.createLinearGradient(0, 0, 192, 192);
          gradient.addColorStop(0, '#3b82f6');
          gradient.addColorStop(1, '#8b5cf6');
          ctx.fillStyle = gradient;
          ctx.beginPath();
          ctx.roundRect(0, 0, 192, 192, 48);
          ctx.fill();
          ctx.fillStyle = '#fff';
          ctx.font = 'bold 64px system-ui, sans-serif';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillText((projectName || '?').slice(0, 2).toUpperCase(), 96, 99);
        }
      }
    }

    function showToast(message, duration = 2500) {
      let toast = document.querySelector('.share-toast');
      if (!toast) {
        toast = document.createElement('div');
        toast.className = 'share-toast';
        document.body.appendChild(toast);
      }
      toast.textContent = message;
      // Force reflow
      toast.offsetHeight;
      toast.classList.add('share-toast--visible');
      setTimeout(() => {
        toast.classList.remove('share-toast--visible');
      }, duration);
    }
  })();

  // Code block copy buttons
  (function initCodeCopy() {
    const content = document.querySelector('.content-body');
    if (!content) return;
    const pres = content.querySelectorAll('pre');
    if (!pres.length) return;

    const COPY_TEXT = document.documentElement.lang?.startsWith('zh') ? '复制' : 'Copy';
    const COPIED_TEXT = document.documentElement.lang?.startsWith('zh') ? '已复制' : 'Copied';

    pres.forEach((pre) => {
      const btn = document.createElement('button');
      btn.className = 'code-block-copy';
      btn.type = 'button';
      btn.textContent = COPY_TEXT;
      btn.setAttribute('aria-label', COPY_TEXT);
      pre.appendChild(btn);

      btn.addEventListener('click', () => {
        const code = pre.querySelector('code');
        const text = code ? code.textContent : pre.textContent;
        navigator.clipboard.writeText(text).then(() => {
          btn.textContent = COPIED_TEXT;
          btn.classList.add('code-block-copy--copied');
          setTimeout(() => {
            btn.textContent = COPY_TEXT;
            btn.classList.remove('code-block-copy--copied');
          }, 2000);
        });
      });
    });
  })();
</script>
