      box-shadow: 0 0 0 3px rgba(10, 132, 255, 0.14);
    }
    .content-body { padding: 16px; }
    .detail-score {
      grid-template-columns: auto auto minmax(0, 1fr) auto;
      gap: 6px;
      align-items: center;
      min-height: 34px;
    }
    .detail-score__left {
      gap: 3px;
    }
    .detail-score__left strong {
      font-size: 1.38rem;
    }
    .score-max {
      font-size: 0.72rem;
    }
    .score-label {
      font-size: 0.74rem;
      line-height: 1.1;
    }
    .detail-actions {
