    }
    .detail-hero__top {
      grid-template-columns: 42px minmax(0, 1fr);
      grid-template-areas:
        "logo info"
        "highlights highlights";
      column-gap: 10px;
      row-gap: 10px;
      align-items: stretch;
    }
    .detail-logo {
      min-width: 36px;
      border-radius: 10px;
    }
    .detail-hero__info {
      align-self: start;
      gap: 4px;
    }
    .detail-hero__info h1 {
      font-size: clamp(1.45rem, 8vw, 2rem);
      line-height: 1.05;
    }
    .detail-desc {
      font-size: 0.9rem;
      line-height: 1.42;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .detail-highlights {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .detail-highlights .hero-metric {
      min-height: 30px;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      width: auto;
      max-width: 100%;
      padding: 5px 8px;
      border-radius: 999px;
      background: rgba(10, 132, 255, 0.06);
    }
    .detail-highlights .hero-metric__label {
      display: inline-flex;
      flex: 0 0 auto;
      grid-column: auto;
      gap: 0;
