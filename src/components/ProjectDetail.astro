---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  categoryName,
  getCategories,
  localizedPath,
  markdownToHtml,
  projectContent,
  projectDescription,
  projectIconUrl,
  statusLabel,
  ui,
} from '../lib/landscape.mjs';

const { lang = 'en', project, allProjects = [] } = Astro.props;
const copy = ui(lang);
const category = getCategories().find((item) => item.key === project.category);
const description = projectDescription(project, lang);
const html = markdownToHtml(projectContent(project, lang));
const avatar = projectIconUrl(project, 128);
const avatarLarge = projectIconUrl(project, 400);
const repoSlug = project.repoSlug || '';
const repoOwner = repoSlug.split('/')[0] || '';
const formattedArchivedDate = project.archivedDate ? new Date(project.archivedDate).toISOString().slice(0, 10) : copy.unknown;
const activityMetricLabel = project.status === 'archived' ? copy.archivedDate : copy.lastCommit;
const activityMetricValue = project.status === 'archived' ? formattedArchivedDate : copy.unknown;

// Compute related projects: score by subCategory > category > shared tags
const relatedProjects = allProjects
  .filter(p => p.slug !== project.slug)
  .map(p => {
    let score = 0;
    if (p.subCategory === project.subCategory) score += 50;
    if (p.category === project.category) score += 20;
    const sharedTags = (p.tags || []).filter(t => (project.tags || []).includes(t)).length;
    score += sharedTags * 5;
    return { project: p, score };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map(r => r.project);
---

<BaseLayout title={project.name} description={description} canonical={localizedPath(`/projects/${project.slug}/`, lang)} lang={lang}>
  <main class="detail-page">
    <nav class="detail-breadcrumb" aria-label="Breadcrumb">
      <a class="detail-breadcrumb__home" href={localizedPath('/', lang)}>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 10.5 12 3l9 7.5"/><path d="M5.5 9.5V20h13V9.5"/></svg>
        <span>{copy.navLandscape}</span>
      </a>
      <span class="breadcrumb-sep" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="m9 6 6 6-6 6"/></svg>
      </span>
      <a class="detail-breadcrumb__current" href={localizedPath(`/categories/${project.category}/`, lang)}>{categoryName(category, lang)}</a>
    </nav>

    <section class="detail-layout">
      <section class="detail-hero">
        <div class="detail-hero__main">
          <div class="detail-hero__top">
            <div class="detail-logo" data-logo-status={project.status}>
              {avatar ? (
                <img src={avatar} alt={`${project.name} logo`} loading="eager" decoding="async" onerror="this.hidden=true;this.nextElementSibling.hidden=false" />
              ) : null}
              <span hidden={Boolean(avatar)}>{project.name.slice(0, 2).toUpperCase()}</span>
            </div>
            <div class="detail-hero__info">
              <div class="detail-title-row">
                <h1>{project.name}</h1>
                <strong class="reference-status detail-title-status" data-reference-status={project.status}>
                  <span class="reference-status__dot"></span>
                  {statusLabel(project.status, lang)}
                </strong>
              </div>
              <p class="detail-desc">{description}</p>
            </div>
            <div class="detail-highlights" aria-label={copy.projectFacts}>
              <span class="hero-metric">
                <span class="hero-metric__label">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  {copy.author}
                </span>
                <strong>{project.author || copy.unknown}</strong>
              </span>
              <span class="hero-metric">
                <span class="hero-metric__label">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  {copy.openSourced}
                </span>
                <strong data-metrics-created>{project.ossDate ? new Date(project.ossDate).toISOString().slice(0, 10) : copy.unknown}</strong>
              </span>
              <span class="hero-metric">
                <span class="hero-metric__label">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="10"/></svg>
                  {activityMetricLabel}
                </span>
                <strong data-metric-last-commit={project.status === 'archived' ? undefined : ''}>{activityMetricValue}</strong>
              </span>
            </div>
          </div>
        </div>

        <aside class="detail-hero__side" aria-label="Project score and actions">
          {project.status !== 'tracked' && (
            <div class="detail-unavailable-warning" data-warning-status={project.status}>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <strong>{lang === 'zh' ? statusLabel(project.status, lang) : statusLabel(project.status, lang)}</strong>
              <p>
                {project.status === 'unavailable'
                  ? (lang === 'zh' ? '项目仓库已无法访问，可能已被删除或暂时封禁。请谨慎参考以下信息。' : 'The repository is no longer accessible. It may have been deleted or temporarily suspended. Use the information below with caution.')
                  : project.status === 'archived'
                  ? (lang === 'zh' ? '项目已被归档或停止维护。以下信息仅作历史参考。' : 'This project has been archived or is no longer maintained. The information below is for historical reference only.')
                  : (lang === 'zh' ? '项目长期不活跃，可能已停止更新。请谨慎参考以下信息。' : 'This project has been inactive for an extended period. Use the information below with caution.')
                }
              </p>
            </div>
          )}
          {project.status === 'tracked' && (
          <div class="detail-score-panel" data-reference-status={project.status} data-lang={lang}>
            <div class="detail-score" data-score-repo={repoSlug}>
              <button class="score-info-btn" type="button" aria-label={lang === 'zh' ? '评分详情' : 'Score details'} data-score-info-toggle>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
              </button>
              <div class="score-ring" data-score-ring>
                <svg viewBox="0 0 64 64" aria-hidden="true">
                  <circle class="score-ring__bg" cx="32" cy="32" r="26" />
                  <circle class="score-ring__fill" cx="32" cy="32" r="26" data-score-arc style="stroke-dasharray:0 163.36" />
                </svg>
                <span class="score-ring__value" data-score-value>--</span>
              </div>
              <div class="detail-score__info">
                <span class="score-kicker">{copy.overallHealth}</span>
                <span class="score-label" data-score-label>{copy.scoreLoading}</span>
              </div>
            </div>
            <div class="score-popover" data-score-popover>
              <div class="score-popover__header">
                <span class="score-popover__title">{copy.scoreBreakdown}</span>
                <span class="score-popover__total" data-score-repo={repoSlug} data-score-value-total>--</span>
              </div>
              <div class="score-popover__rows">
                <div class="score-popover__row">
                  <span class="score-popover__icon" style="--dot-color:#3b82f6">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                  </span>
                  <div class="score-popover__meta">
                    <span class="score-popover__label">{copy.activity}</span>
                    <div class="score-popover__bar"><div class="score-popover__fill" data-score-repo={repoSlug} data-score-dimension="activity" style="--fill-color:linear-gradient(90deg,#3b82f6,#60a5fa);width:0%"></div></div>
                  </div>
                  <span class="score-popover__val" data-score-repo={repoSlug} data-score-activity>--</span>
                </div>
                <div class="score-popover__row">
                  <span class="score-popover__icon" style="--dot-color:#8b5cf6">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                  </span>
                  <div class="score-popover__meta">
                    <span class="score-popover__label">{copy.community}</span>
                    <div class="score-popover__bar"><div class="score-popover__fill" data-score-repo={repoSlug} data-score-dimension="community" style="--fill-color:linear-gradient(90deg,#8b5cf6,#a78bfa);width:0%"></div></div>
                  </div>
                  <span class="score-popover__val" data-score-repo={repoSlug} data-score-community>--</span>
                </div>
                <div class="score-popover__row">
                  <span class="score-popover__icon" style="--dot-color:#10b981">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  </span>
                  <div class="score-popover__meta">
                    <span class="score-popover__label">{copy.quality}</span>
                    <div class="score-popover__bar"><div class="score-popover__fill" data-score-repo={repoSlug} data-score-dimension="quality" style="--fill-color:linear-gradient(90deg,#10b981,#34d399);width:0%"></div></div>
                  </div>
                  <span class="score-popover__val" data-score-repo={repoSlug} data-score-quality>--</span>
                </div>
                <div class="score-popover__row">
                  <span class="score-popover__icon" style="--dot-color:#f59e0b">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M12 6v6l4 2"/></svg>
                  </span>
                  <div class="score-popover__meta">
                    <span class="score-popover__label">{copy.sustainability}</span>
                    <div class="score-popover__bar"><div class="score-popover__fill" data-score-repo={repoSlug} data-score-dimension="sustainability" style="--fill-color:linear-gradient(90deg,#f59e0b,#fbbf24);width:0%"></div></div>
                  </div>
                  <span class="score-popover__val" data-score-repo={repoSlug} data-score-sustainability>--</span>
                </div>
              </div>
              <a class="score-popover__link" href={localizedPath('/methodology/', lang)}>
                {lang === 'zh' ? '查看评分方法' : 'View methodology'}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>
          )}

          <div class="detail-actions">
            {project.status === 'unavailable' ? (
              <div class="repo-record" aria-label={copy.originalRepository}>
                <span class="repo-record__label">{copy.originalRepository}</span>
                <span class="repo-record__value">{project.repo}</span>
              </div>
            ) : (
              <a class="btn-primary" href={project.repo} target="_blank" rel="noopener noreferrer">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                GitHub
              </a>
            )}
            {project.homepage && (
              <a class="btn-secondary" href={project.homepage} target="_blank" rel="noopener noreferrer">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                {copy.website || 'Website'}
              </a>
            )}
          </div>
        </aside>
      </section>

      <article class="content-card">
        <div class="content-body markdown" set:html={html} />

        <!-- Share -->
        <div class="share-bar" data-share-section>
          <span class="share-bar__label">{copy.share}</span>
          <button class="share-btn" data-share-generate type="button" title={copy.shareCard}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          </button>
          <a class="share-btn" data-share-x href="#" target="_blank" rel="noopener noreferrer" title={lang === 'zh' ? '分享到 X' : 'Share on X'}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a class="share-btn" data-share-linkedin href="#" target="_blank" rel="noopener noreferrer" title={lang === 'zh' ? '分享到 LinkedIn' : 'Share on LinkedIn'}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <button class="share-btn" data-share-copy type="button" title={copy.copyLink}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          </button>
        </div>
      </article>

      <!-- Hidden share card template -->
      <div class="share-card-template" data-share-card-template style="position:fixed;left:-9999px;top:0;z-index:-1;">
        <div class="sc" style="width:1200px;height:630px;display:flex;flex-direction:column;font-family:'Inter',system-ui,-apple-system,sans-serif;overflow:hidden;background:#ffffff;">
          <!-- Top accent bar -->
          <div style="height:6px;background:linear-gradient(90deg,#0a84ff,#60a5fa,#a78bfa);flex-shrink:0;"></div>

          <!-- Header -->
          <div style="display:flex;padding:44px 56px 0;gap:24px;">
            <div style="flex:1;min-width:0;">
              <!-- Row 1: Logo + Name -->
              <div style="display:flex;align-items:center;gap:14px;">
                <canvas data-sc-logo-canvas data-sc-logo-src={avatarLarge || ''} width="192" height="192" style="width:48px;height:48px;border-radius:12px;object-fit:cover;flex-shrink:0;"></canvas>
                <div data-sc-name style="font-size:36px;font-weight:700;color:#0f172a;line-height:1.1;letter-spacing:-0.03em;">{project.name}</div>
              </div>
              <!-- Row 2: Description -->
              <div data-sc-desc style="font-size:20px;line-height:1.5;color:#475569;margin-top:14px;max-width:680px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{description}</div>
              <!-- Row 3: GitHub repo + meta -->
              <div style="display:flex;align-items:center;gap:16px;margin-top:12px;flex-wrap:wrap;">
                <div style="display:flex;align-items:center;gap:8px;">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="#64748b"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                  <span data-sc-repo style="font-size:17px;color:#64748b;font-weight:600;">{project.repo ? project.repo.replace('https://github.com/', 'github.com/') : ''}</span>
                </div>
                <div style="width:1px;height:18px;background:#cbd5e1;"></div>
                <div style="display:flex;align-items:center;gap:6px;">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  <span style="font-size:16px;color:#64748b;font-weight:500;">{project.author || (lang === 'zh' ? '未知' : 'Unknown')}</span>
                </div>
                {project.ossDate && (
                  <div style="display:flex;align-items:center;gap:6px;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    <span style="font-size:16px;color:#64748b;font-weight:500;">{project.ossDate ? new Date(project.ossDate).toISOString().slice(0, 10) : ''}</span>
                  </div>
                )}
              </div>
            </div>
            <!-- Health score badge -->
            <div style="flex-shrink:0;text-align:center;padding:24px 32px;min-width:150px;background:#eff6ff;border-radius:20px;">
              <div style="font-size:13px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#0a84ff;margin-bottom:6px;">{copy.overallHealth}</div>
              <div data-sc-health style="font-size:60px;font-weight:900;line-height:1;color:#0a84ff;">--</div>
              <div data-sc-health-label style="font-size:16px;font-weight:700;margin-top:6px;color:#059669;"></div>
            </div>
          </div>

          <!-- Score card: metrics + dimensions -->
          <div style="margin:32px 56px 0;background:#f8fafc;border-radius:16px;padding:24px 32px;">
            <!-- GitHub metrics -->
            <div style="display:flex;gap:44px;">
              <div style="display:flex;align-items:center;gap:10px;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <span data-sc-stars style="font-size:24px;font-weight:800;color:#0f172a;">--</span>
                <span style="font-size:16px;color:#94a3b8;">Stars</span>
              </div>
              <div style="display:flex;align-items:center;gap:10px;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><circle cx="12" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><circle cx="18" cy="6" r="3"/><path d="M18 9v1a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V9"/><path d="M12 12v3"/></svg>
                <span data-sc-forks style="font-size:24px;font-weight:800;color:#0f172a;">--</span>
                <span style="font-size:16px;color:#94a3b8;">Forks</span>
              </div>
              <div style="display:flex;align-items:center;gap:10px;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 15h8M9 9h.01M15 9h.01"/></svg>
                <span data-sc-issues style="font-size:24px;font-weight:800;color:#0f172a;">--</span>
                <span style="font-size:16px;color:#94a3b8;">Issues</span>
              </div>
              <div style="display:flex;align-items:center;gap:10px;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <span data-sc-contributors style="font-size:24px;font-weight:800;color:#0f172a;">--</span>
                <span style="font-size:16px;color:#94a3b8;">Contributors</span>
              </div>
            </div>

            <!-- Divider -->
            <div style="height:1px;background:#e2e8f0;margin:18px 0;"></div>

            <!-- Score dimensions - progress bars -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px 40px;">
              <div>
                <div style="display:flex;justify-content:space-between;font-size:15px;margin-bottom:5px;"><span style="color:#64748b;font-weight:600;">{copy.activity}</span><span data-sc-activity style="font-weight:800;color:#0f172a;">--</span></div>
                <div style="height:8px;border-radius:99px;background:#e2e8f0;overflow:hidden;"><div data-sc-bar-activity style="height:100%;border-radius:99px;background:linear-gradient(90deg,#3b82f6,#60a5fa);width:0%;"></div></div>
              </div>
              <div>
                <div style="display:flex;justify-content:space-between;font-size:15px;margin-bottom:5px;"><span style="color:#64748b;font-weight:600;">{copy.community}</span><span data-sc-community style="font-weight:800;color:#0f172a;">--</span></div>
                <div style="height:8px;border-radius:99px;background:#e2e8f0;overflow:hidden;"><div data-sc-bar-community style="height:100%;border-radius:99px;background:linear-gradient(90deg,#8b5cf6,#a78bfa);width:0%;"></div></div>
              </div>
              <div>
                <div style="display:flex;justify-content:space-between;font-size:15px;margin-bottom:5px;"><span style="color:#64748b;font-weight:600;">{copy.quality}</span><span data-sc-quality style="font-weight:800;color:#0f172a;">--</span></div>
                <div style="height:8px;border-radius:99px;background:#e2e8f0;overflow:hidden;"><div data-sc-bar-quality style="height:100%;border-radius:99px;background:linear-gradient(90deg,#10b981,#34d399);width:0%;"></div></div>
              </div>
            <div>
              <div style="display:flex;justify-content:space-between;font-size:15px;margin-bottom:5px;"><span style="color:#64748b;font-weight:600;">{copy.sustainability}</span><span data-sc-sustainability style="font-weight:800;color:#0f172a;">--</span></div>
              <div style="height:8px;border-radius:99px;background:#e2e8f0;overflow:hidden;"><div data-sc-bar-sustainability style="height:100%;border-radius:99px;background:linear-gradient(90deg,#f59e0b,#fbbf24);width:0%;"></div></div>
            </div>
            </div>
          </div>

          <!-- Bottom: branding left + QR right -->
          <div style="margin-top:auto;display:flex;align-items:flex-end;justify-content:space-between;padding:0 56px 36px;">
            <div style="display:flex;align-items:center;gap:14px;">
              <svg width="36" height="36" viewBox="0 0 64 64"><rect width="64" height="64" rx="14" fill="#0a84ff"/><path d="M16 45 32 17l16 28" fill="none" stroke="#fff" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="32" cy="36" r="6" fill="none" stroke="#fff" stroke-width="4"/><path d="M24 45h16" fill="none" stroke="#fff" stroke-width="4" stroke-linecap="round"/></svg>
              <div>
                <div style="font-size:17px;font-weight:800;color:#0f172a;">AI Native Landscape</div>
                <div style="font-size:13px;color:#94a3b8;">landscape.jimmysong.io</div>
              </div>
            </div>
            <div style="text-align:center;">
              <div style="font-size:12px;color:#94a3b8;margin-bottom:6px;">{lang === 'zh' ? '扫码查看详情' : 'Scan to view'}</div>
              <canvas data-sc-qrcode width="88" height="88" style="border-radius:10px;"></canvas>
            </div>
          </div>
        </div>
      </div>

      <aside class="detail-sidebar">
        {project.status === 'tracked' && (
        <div class="sidebar-card github-card">
          <h3>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            {copy.githubMetrics}
          </h3>
          <div class="detail-meta" aria-label={copy.githubMetrics}>
            <div class="metric-group">
              <span class="metric-row">
                <span class="metric-row__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></span>
                <span class="metric-row__label">{copy.stars}</span>
                <strong data-metrics-stars>--</strong>
              </span>
              <span class="metric-row">
                <span class="metric-row__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><circle cx="18" cy="6" r="3"/><path d="M18 9v1a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V9"/><path d="M12 12v3"/></svg></span>
                <span class="metric-row__label">{copy.forks}</span>
                <strong data-metrics-forks>--</strong>
              </span>
              <span class="metric-row">
                <span class="metric-row__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
                <span class="metric-row__label">{copy.contributors}</span>
                <strong data-metrics-contributors>--</strong>
              </span>
              <span class="metric-row">
                <span class="metric-row__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 15h8M9 9h.01M15 9h.01"/></svg></span>
                <span class="metric-row__label">{copy.openIssues}</span>
                <strong data-metrics-issues>--</strong>
              </span>
            </div>
            <div class="metric-separator"></div>
            <div class="metric-group">
              <span class="metric-row" data-github-language-card hidden>
                <span class="metric-row__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10"/><path d="m18 20-6-6-6 6"/></svg></span>
                <span class="metric-row__label">{copy.primaryLanguage}</span>
                <strong data-metrics-language>{copy.unknown}</strong>
              </span>
              <span class="metric-row">
                <span class="metric-row__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
                <span class="metric-row__label">{copy.license}</span>
                <strong data-metrics-license>{project.license && project.license !== 'Unknown' ? project.license : copy.unknown}</strong>
              </span>
              <span class="metric-row">
                <span class="metric-row__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg></span>
                <span class="metric-row__label">{copy.commitsLastYear}</span>
                <strong data-metric-commits-year>{copy.unknown}</strong>
              </span>
              <span class="metric-row">
                <span class="metric-row__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span>
                <span class="metric-row__label">{copy.repoCreatedAt}</span>
                <strong data-metrics-created>{copy.unknown}</strong>
              </span>
            </div>
          </div>
        </div>
        )}

        <!-- Related Projects -->
        {relatedProjects.length > 0 && (
          <div class="sidebar-card related-card">
            <h3>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 3h5v5"/><path d="M21 3l-7 7"/><path d="M8 21H3v-5"/><path d="M3 21l7-7"/></svg>
              {copy.relatedProjects}
            </h3>
            <div class="related-list">
              {relatedProjects.map(rp => {
                const rpIcon = projectIconUrl(rp, 64);
                const rpDesc = projectDescription(rp, lang);
                return (
                  <a class="related-item" href={localizedPath(`/projects/${rp.slug}/`, lang)}>
                    <div class="related-item__logo">
                      {rpIcon ? (
                        <img src={rpIcon} alt={`${rp.name} logo`} loading="lazy" decoding="async" onerror="this.hidden=true;this.nextElementSibling.hidden=false" />
                      ) : null}
                      <span hidden={Boolean(rpIcon)}>{rp.name.slice(0, 2).toUpperCase()}</span>
                    </div>
                    <div class="related-item__info">
                      <strong class="related-item__name">{rp.name}</strong>
                      <span class="related-item__desc">{rpDesc}</span>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}
      </aside>
    </section>
  </main>
</BaseLayout>

<style>
  .detail-page {
    width: min(1180px, calc(100% - 32px));
  }

  .detail-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    padding: 8px 12px;
    margin-bottom: 8px;
    border: 1px solid color-mix(in srgb, var(--accent) 18%, var(--border));
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent-soft) 42%, var(--surface) 58%);
    font-size: 0.82rem;
    line-height: 1;
    color: var(--muted);
    min-width: 0;
  }
  .detail-breadcrumb__home,
  .detail-breadcrumb__current {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--accent);
    font-weight: 700;
    text-decoration: none;
  }
  .detail-breadcrumb__home:hover,
  .detail-breadcrumb__current:hover,
  .detail-breadcrumb__home:focus-visible,
  .detail-breadcrumb__current:focus-visible {
    color: color-mix(in srgb, var(--accent) 72%, white);
  }
  .detail-breadcrumb__home svg,
  .breadcrumb-sep svg {
    width: 14px;
    height: 14px;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
    flex-shrink: 0;
  }
  .breadcrumb-sep {
    display: inline-flex;
    align-items: center;
    color: var(--muted);
    opacity: 0.7;
  }

  .detail-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(280px, 28vw, 340px);
    grid-template-areas:
      "hero hero"
      "content sidebar";
    gap: 20px;
    align-items: start;
  }

  .detail-hero {
    grid-area: hero;
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(280px, 28vw, 340px);
    gap: clamp(14px, 2.2vw, 24px);
    align-items: stretch;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
    padding: clamp(18px, 2vw, 24px);
    border-top: 2px solid rgba(10, 132, 255, 0.64);
  }
  html[data-theme='dark'] .detail-hero { border-top-color: rgba(10,132,255,0.58); }

  .detail-hero__main {
    min-width: 0;
    display: grid;
    align-content: center;
  }

  .detail-hero__side {
    min-width: 0;
    display: grid;
    gap: 10px;
    align-content: center;
    padding-left: 28px;
    border-left: 1px solid var(--border);
  }

  .detail-hero__top {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    grid-template-areas:
      "logo info"
      "highlights highlights";
    column-gap: 12px;
    row-gap: 10px;
    align-items: stretch;
  }
  .detail-logo {
    grid-area: logo;
    aspect-ratio: 1;
    max-height: 80px;
    min-height: 40px;
    border-radius: 10px;
    overflow: hidden;
    display: grid;
    place-items: center;
    background: var(--accent-soft);
    border: 1px solid var(--border);
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--accent);
  }
  .detail-logo img { width: 100%; height: 100%; object-fit: cover; }
  .detail-logo[data-logo-status="archived"] img { filter: grayscale(1) opacity(0.5); }
  .detail-logo[data-logo-status="inactive"] img { filter: grayscale(0.6) opacity(0.7); }
  .detail-hero__info {
    grid-area: info;
    min-width: 0;
    display: grid;
    align-content: start;
    gap: 8px;
  }
  .detail-title-row {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
    flex-wrap: wrap;
  }
  .detail-hero__info h1 {
    margin: 0;
    font-size: clamp(1.3rem, 2vw, 1.8rem);
    line-height: 1.1;
  }
  .detail-desc {
    margin: 0;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.4;
    max-width: 62ch;
  }
  .detail-highlights {
    grid-area: highlights;
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 0;
    max-width: 68ch;
  }
  .detail-highlights .hero-metric {
    min-height: 34px;
    display: inline-grid;
    grid-template-columns: auto auto;
    align-items: center;
    width: auto;
    max-width: 100%;
    gap: 7px;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(10, 132, 255, 0.055);
  }
  .detail-highlights .hero-metric__label {
    grid-column: auto;
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    gap: 5px;
    font-size: 0.72rem;
    line-height: 1;
  }
  .detail-highlights .hero-metric__label svg {
    width: 15px;
    height: 15px;
    flex-basis: 15px;
  }
  .detail-highlights .hero-metric strong {
    grid-column: auto;
    display: inline-block;
    max-width: 14rem;
    font-size: 0.78rem;
    line-height: 1;
    align-self: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .detail-unavailable-warning {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 28px 20px;
    border-radius: 16px;
    border: 1px solid rgba(239,68,68,0.25);
    background: rgba(239,68,68,0.06);
    text-align: center;
    color: #ef4444;
  }
  .detail-unavailable-warning[data-warning-status="archived"] {
    border-color: rgba(148,163,184,0.25);
    background: rgba(148,163,184,0.08);
    color: #94a3b8;
  }
  .detail-unavailable-warning[data-warning-status="inactive"] {
    border-color: rgba(245,158,11,0.25);
    background: rgba(245,158,11,0.06);
    color: #f59e0b;
  }
  .detail-unavailable-warning svg { opacity: 0.8; }
  .detail-unavailable-warning strong { font-size: 1rem; }
  .detail-unavailable-warning p {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--muted);
  }

  .detail-score-panel {
    position: relative;
    display: grid;
    padding: 10px 12px;
    border: 1px solid rgba(10, 132, 255, 0.22);
    border-radius: 14px;
    background:
      radial-gradient(circle at top left, rgba(96, 165, 250, 0.2), transparent 52%),
      linear-gradient(135deg, rgba(10, 132, 255, 0.12), rgba(80, 181, 124, 0.1));
    box-shadow: 0 8px 18px rgba(10, 132, 255, 0.06);
  }

  .detail-score {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
    background: transparent;
  }

  .score-ring {
    position: relative;
    width: 62px;
    height: 62px;
    flex-shrink: 0;
    filter: drop-shadow(0 6px 14px rgba(59, 130, 246, 0.12));
  }
  .score-ring svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }
  .score-ring__bg {
    fill: none;
    stroke: var(--surface-soft);
    stroke-width: 5;
  }
  html[data-theme='dark'] .score-ring__bg {
    stroke: rgba(255,255,255,0.08);
  }
  .score-ring__fill {
    fill: none;
    stroke: var(--accent);
    stroke-width: 5;
    stroke-linecap: round;
    transition: stroke-dasharray 0.6s ease;
  }
  .score-ring__value {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.18rem;
    font-weight: 800;
    color: var(--text);
    line-height: 1;
  }

  .detail-score__info {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .score-kicker {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    line-height: 1;
  }

  .score-label {
    font-size: clamp(0.9rem, 0.92rem + 0.36vw, 1.14rem);
    font-weight: 800;
    color: var(--ok);
    line-height: 1;
  }

  .detail-score-panel[data-lang='en'] .score-kicker {
    font-size: 0.58rem;
    letter-spacing: 0.04em;
  }

  .detail-score-panel[data-lang='en'] .score-label {
    font-size: clamp(0.82rem, 0.84rem + 0.24vw, 0.98rem);
    line-height: 1.03;
  }

  /* Score info button — top-right corner */
  .score-info-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    display: grid;
    place-items: center;
    width: 22px;
    height: 22px;
    border-radius: 99px;
    border: 1px solid rgba(10, 132, 255, 0.2);
    background: rgba(10, 132, 255, 0.06);
    color: var(--accent);
    cursor: pointer;
    transition: all 0.2s;
    padding: 0;
    z-index: 2;
  }
  .score-info-btn:hover {
    background: rgba(10, 132, 255, 0.14);
    border-color: rgba(10, 132, 255, 0.4);
  }
  .score-info-btn svg { width: 12px; height: 12px; }

  /* Score popover — redesigned */
  .score-popover {
    position: fixed;
    z-index: 9999;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--surface);
    box-shadow: 0 8px 30px rgba(0,0,0,0.12), 0 0 0 1px rgba(0,0,0,0.04);
    display: none;
    flex-direction: column;
    width: 260px;
    overflow: hidden;
    animation: popover-in 0.18s ease-out;
  }
  @keyframes popover-in {
    from { opacity: 0; transform: translateY(-4px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  html[data-theme='dark'] .score-popover { box-shadow: 0 8px 30px rgba(0,0,0,0.45), 0 0 0 1px rgba(255,255,255,0.06); }
  .score-popover--visible { display: flex; }

  .score-popover__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px 10px;
    border-bottom: 1px solid var(--border);
  }
  .score-popover__title {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
  }
  .score-popover__total {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text);
    line-height: 1;
  }

  .score-popover__rows {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 6px 0;
  }
  .score-popover__row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    transition: background 0.15s;
  }
  .score-popover__row:hover { background: rgba(10,132,255,0.04); }
  html[data-theme='dark'] .score-popover__row:hover { background: rgba(255,255,255,0.04); }

  .score-popover__icon {
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    flex-shrink: 0;
    background: color-mix(in srgb, var(--dot-color) 10%, transparent);
    color: var(--dot-color);
  }
  html[data-theme='dark'] .score-popover__icon { background: color-mix(in srgb, var(--dot-color) 15%, transparent); }

  .score-popover__meta {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .score-popover__label {
    font-size: 0.74rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1;
  }
  .detail-score-panel[data-lang='zh'] .score-popover__label { }
  .score-popover__bar {
    height: 4px;
    border-radius: 99px;
    background: var(--surface-soft);
    overflow: hidden;
  }
  html[data-theme='dark'] .score-popover__bar { background: rgba(255,255,255,0.08); }
  .score-popover__fill {
    height: 100%;
    border-radius: 99px;
    background: var(--fill-color);
    transition: width 0.5s ease;
  }
  .score-popover__val {
    font-size: 0.82rem;
    font-weight: 700;
    text-align: right;
    min-width: 28px;
    color: var(--text);
    line-height: 1;
  }

  .score-popover__link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
