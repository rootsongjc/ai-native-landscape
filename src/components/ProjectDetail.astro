  .sidebar-card h3 svg { color: var(--accent); flex-shrink: 0; }

  .score-card { border-left: 3px solid var(--accent); }
  .github-card { border-left: 3px solid var(--accent); }

  .score-row {
    display: grid;
    grid-template-columns: 90px 1fr 32px;
    align-items: center;
    gap: 8px;
    padding: 8px 0;
    border-bottom: 1px solid rgba(0,0,0,0.04);
    font-size: 0.82rem;
  }
  html[data-theme='dark'] .score-row { border-bottom-color: rgba(255,255,255,0.06); }
  .score-row:last-child { border-bottom: none; }
  .score-row span:first-child { color: var(--muted); font-weight: 600; }
  .score-row__bar { height: 6px; border-radius: 99px; background: var(--surface-soft); overflow: hidden; }
  .score-row__val { font-weight: 700; text-align: right; font-size: 0.88rem; }
  .fill-activity { background: linear-gradient(90deg, #3b82f6, #60a5fa); height: 100%; border-radius: 99px; transition: width 0.5s; }
  .fill-community { background: linear-gradient(90deg, #8b5cf6, #a78bfa); height: 100%; border-radius: 99px; transition: width 0.5s; }
  .fill-quality { background: linear-gradient(90deg, #10b981, #34d399); height: 100%; border-radius: 99px; transition: width 0.5s; }
  .fill-sustainability { background: linear-gradient(90deg, #f59e0b, #fbbf24); height: 100%; border-radius: 99px; transition: width 0.5s; }

  @media (min-width: 1280px) {
    .detail-score-panel {
      position: static;
    }
  }

  @media (max-width: 1120px) {
    .detail-page {
      width: min(1000px, calc(100% - 32px));
    }
    .detail-layout {
      grid-template-columns: minmax(0, 1fr) 300px;
      gap: 18px;
    }
  }

  @media (max-width: 900px) {
    .detail-layout {
      grid-template-columns: 1fr;
      grid-template-areas:
        "hero"
        "content"
        "sidebar";
    }
    .detail-hero {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .detail-hero__side {
      padding-left: 0;
      padding-top: 14px;
      border-left: 0;
      border-top: 1px solid var(--border);
    }
    .detail-meta { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  @media (max-width: 720px) {
    .detail-page {
      width: min(100% - 16px, 720px);
    }
    .detail-breadcrumb {
      padding-bottom: 8px;
      font-size: 0.82rem;
    }
    .detail-hero {
      grid-template-columns: 1fr;
      gap: 10px;
