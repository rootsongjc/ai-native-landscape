  .content-body :global(p) { color: var(--muted); line-height: 1.75; margin: 0 0 1rem; font-size: 0.95rem; }
  .content-body :global(ul), .content-body :global(ol) { color: var(--muted); line-height: 1.7; padding-left: 1.5rem; margin: 0 0 1rem; }
  .content-body :global(li) { margin-bottom: 0.4rem; }
  .content-body :global(li)::marker { color: var(--accent); }
  .content-body :global(strong) { color: var(--text); }

  .detail-sidebar {
    grid-area: sidebar;
    min-width: 0;
    display: grid;
    gap: 16px;
  }
  .sidebar-card {
    min-width: 0;
    overflow: hidden;
