---
import BaseLayout from '../layouts/BaseLayout.astro';
import aboutEn from '../data/about.en.md?raw';
import aboutZh from '../data/about.zh.md?raw';
import { localizedPath, markdownToHtml, ui } from '../lib/landscape.mjs';

const { lang = 'en' } = Astro.props;
const copy = ui(lang);
const content = lang === 'zh' ? aboutZh : aboutEn;
const html = markdownToHtml(content);
---

<BaseLayout title={copy.aboutPageTitle} description={copy.aboutPageDescription} canonical={localizedPath('/about/', lang)} lang={lang}>
  <main class="about-page">
    <article class="about-content markdown" set:html={html} />
  </main>
</BaseLayout>

<style>
  .about-page {
    max-width: 860px;
    margin: 0 auto;
    padding: 24px 16px 56px;
  }

  .about-content {
    padding: 4px 0 0;
  }

  .about-content :global(h1) {
    margin: 0 0 18px;
    font-size: clamp(1.8rem, 3vw, 2.7rem);
    line-height: 1.04;
  }

  .about-content :global(h2) {
    margin: 2rem 0 0.8rem;
    padding-bottom: 0.45rem;
    border-bottom: 1px solid var(--border);
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .about-content :global(p),
  .about-content :global(ul) {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.75;
  }

  .about-content :global(p) {
    margin: 0 0 1rem;
  }

  .about-content :global(ul) {
    margin: 0 0 1rem;
    padding-left: 1.35rem;
  }

  .about-content :global(li) {
    margin-bottom: 0.45rem;
  }

  .about-content :global(li)::marker {
    color: var(--accent);
  }

  .about-content :global(a) {
    color: var(--accent);
    text-decoration: none;
  }

  @media (max-width: 720px) {
    .about-page {
      padding: 20px 16px 44px;
    }

    .about-content :global(h1) {
      margin-bottom: 14px;
      font-size: clamp(1.56rem, 6.5vw, 2rem);
    }

    .about-content :global(h2) {
      font-size: 1.08rem;
    }
  }
</style>