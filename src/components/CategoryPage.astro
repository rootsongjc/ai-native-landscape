---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  categoryDescription,
  categoryName,
  getLandscape,
  legacyCategoryTargets,
  localizedPath,
  projectDescription,
  projectIconUrl,
  scoreLabel,
  statusLabel,
  subCategoryName,
  ui,
} from '../lib/landscape.mjs';

const { lang = 'en', category, canonicalCategoryKey = category.key } = Astro.props;
const copy = ui(lang);
const landscape = getLandscape();
const isLegacyCategory = !landscape.byCategory[category.key] && legacyCategoryTargets(category.key).length > 0;
const resolvedKeys = isLegacyCategory ? legacyCategoryTargets(category.key) : [category.key];
const projects = resolvedKeys.flatMap((key) => landscape.byCategory[key] || []);

const grouped = (category.subcategories || []).map((subCategory) => ({
  ...subCategory,
  projects: projects.filter((project) => project.subCategory === subCategory.key),
})).filter((item) => item.projects.length > 0);

const allTags = Array.from(new Set(projects.flatMap((project) => project.tags || []))).sort();
const usedStatuses = [...new Set(projects.map((p) => p.status).filter(Boolean))];
const statusOrder = ['tracked', 'unavailable', 'archived', 'inactive'];
const legendStatuses = [...statusOrder, ...usedStatuses.filter((status) => !statusOrder.includes(status))];
const title = `${categoryName(category, lang)}`;
const description = categoryDescription(category, lang);
---

<BaseLayout title={title} description={description} canonical={localizedPath(`/categories/${canonicalCategoryKey}/`, lang)} lang={lang}>
  <main class="category-page category-page--grouped">
    <nav class="back-link" aria-label="Breadcrumb">
      <a class="back-link__home" href={localizedPath('/', lang)}>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 10.5 12 3l9 7.5"/><path d="M5.5 9.5V20h13V9.5"/></svg>
        <span>{copy.navLandscape}</span>
      </a>
      <span class="back-link__sep" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="m9 6 6 6-6 6"/></svg>
      </span>
      <span class="back-link__current">{categoryName(category, lang)}</span>
    </nav>
    <section class="page-heading">
      <h1>{categoryName(category, lang)}</h1>
      <p>{description}</p>
      <div class="category-page__meta" aria-label={lang === 'zh' ? '分类摘要' : 'Category summary'}>
        <span class="category-page__meta-item">
          <strong>{projects.length}</strong>
          <span>{copy.projects}</span>
        </span>
        <span class="category-page__meta-item">
          <strong>{grouped.length}</strong>
          <span>{copy.subCategory}</span>
        </span>
        <span class="category-page__meta-item">
          <strong>{allTags.length}</strong>
          <span>{lang === 'zh' ? '标签' : 'Tags'}</span>
        </span>
      </div>
      <div class="status-legend">
        {legendStatuses.map((s) => (
          <span class="status-legend__item"><span class={`status-dot status-dot--${s}`} />{statusLabel(s, lang)}</span>
        ))}
      </div>
      {isLegacyCategory && <p class="legacy-notice">{copy.legacyCategoryNotice}</p>}
    </section>

    <section class="toolbar toolbar--category" aria-label="Category filters">
      <div class="category-toolbar__search">
        <label class="search-field search-field--filter">
          <svg class="filter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
          </svg>
          <input data-filter-search type="search" placeholder={copy.filterPlaceholder} />
        </label>
      </div>
      <div class="category-toolbar__filters">
        <label>
          <span>{copy.subCategory}</span>
          <select data-filter-subcategory>
            <option value="">{copy.allSubCategories}</option>
            {grouped.map((subCategory) => <option value={subCategory.key}>{subCategoryName(subCategory.key, lang)}</option>)}
          </select>
        </label>
        <label>
          <span>{copy.status}</span>
          <select data-filter-status>
            <option value="">{copy.allStatus}</option>
            {statusOrder.map((status) => <option value={status}>{statusLabel(status, lang)}</option>)}
          </select>
        </label>
        <label>
          <span>{copy.filterByTag}</span>
          <select data-filter-tag>
            <option value="">{copy.allTags}</option>
            {allTags.map((tag) => <option value={tag}>{tag}</option>)}
          </select>
        </label>
        <label>
          <span>{copy.sort}</span>
          <select data-filter-sort>
            <option value="score">{copy.score}</option>
            <option value="name">{copy.name}</option>
            <option value="newest">{copy.ossDate}</option>
          </select>
        </label>
      </div>
      <div class="category-toolbar__actions" style="align-self: end;">
        <button class="button button-secondary" type="button" data-reset>{copy.resetFilters}</button>
      </div>
    </section>

    <section
      class="subcategory-board"
      data-board
      data-project-label-one={lang === 'zh' ? copy.projects.toLowerCase() : 'project'}
      data-project-label-many={copy.projects.toLowerCase()}
    >
      {grouped.map((subCategory) => (
        <section class="subcategory-group" data-group data-subcategory={subCategory.key}>
          <button class="subcategory-heading" type="button" data-toggle aria-expanded="true">
            <span>
              <strong>{subCategoryName(subCategory.key, lang)}</strong>
              <small data-group-count>{subCategory.projects.length} {copy.projects.toLowerCase()}</small>
            </span>
            <span class="chevron">⌄</span>
          </button>
          <p>{subCategory.description?.[lang] || subCategory.description?.en || ''}</p>
          <div class="project-list">
            {subCategory.projects.map((project) => {
              const avatar = projectIconUrl(project);
              return (
                <article
                  class="project-list-item"
                  data-card
                  data-repo={project.repoSlug}
                  data-name={project.name.toLowerCase()}
                  data-status={project.status}
                  data-tags={(project.tags || []).join(' ')}
                  data-score=""
                  data-oss-date={project.ossDate || ''}
                  data-subcategory={project.subCategory}
                  data-search={`${project.name} ${project.slug} ${(project.tags || []).join(' ')} ${projectDescription(project, 'zh')} ${projectDescription(project, 'en')}`.toLowerCase()}
                >
                  <div class="project-list-main">
                    <div class="logo project-logo">
                      {avatar && (
                        <img
                          src={avatar}
                          alt={`${project.name} logo`}
                          loading="lazy"
                          decoding="async"
                          onerror="this.hidden=true;this.nextElementSibling.hidden=false"
                        />
                      )}
                      <span hidden={Boolean(avatar)}>{project.name.slice(0, 2).toUpperCase()}</span>
                    </div>
                    <div class="project-list-copy">
                      <h2><a href={localizedPath(`/projects/${project.slug}/`, lang)}>{project.name}</a></h2>
                      <p>{projectDescription(project, lang)}</p>
                    </div>
                  </div>
                  <div class="project-list-side">
                    <div class="project-score" data-score-repo={project.repoSlug}>
                      <strong data-score-value>--</strong>
                      <span data-score-label>{copy.scoreLoading}</span>
                    </div>
                    <span class={`status-dot status-dot--${project.status}`} title={statusLabel(project.status, lang)} />
                    <div class="card-actions card-actions--stacked">
                      <a class="card-action card-action--icon" href={project.repo} target="_blank" rel="noopener noreferrer" title="GitHub">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"/></svg>
                      </a>
                      {project.homepage && <a class="card-action card-action--icon" href={project.homepage} target="_blank" rel="noopener noreferrer" title={copy.website}>
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                      </a>}
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      ))}
    </section>

    <p class="empty-state" data-empty hidden>{copy.noProjects}</p>
  </main>

  <script>
    const locale = document.documentElement.lang.startsWith('zh') ? 'zh' : 'en';
    const search = document.querySelector('[data-filter-search]');
    const subCategory = document.querySelector('[data-filter-subcategory]');
    const status = document.querySelector('[data-filter-status]');
    const tag = document.querySelector('[data-filter-tag]');
    const sort = document.querySelector('[data-filter-sort]');
    const empty = document.querySelector('[data-empty]');
    const board = document.querySelector('[data-board]');
    const projectLabelOne = board?.dataset.projectLabelOne || 'project';
    const projectLabelMany = board?.dataset.projectLabelMany || 'projects';
    const groups = Array.from(document.querySelectorAll('[data-group]'));

    function formatProjectCount(count) {
      const label = count === 1 ? projectLabelOne : projectLabelMany;
      return `${count} ${label}`;
    }

    function applyFilters() {
      const q = search.value.trim().toLowerCase();
      const subCategoryValue = subCategory.value;
      const statusValue = status.value;
      const tagValue = tag.value;
      let visible = 0;

      groups.forEach((group) => {
        const cards = Array.from(group.querySelectorAll('[data-card]'));
        cards
          .sort((a, b) => {
            if (sort.value === 'name') return a.dataset.name.localeCompare(b.dataset.name);
            if (sort.value === 'newest') return (b.dataset.ossDate || '').localeCompare(a.dataset.ossDate || '');
            return Number(b.dataset.score) - Number(a.dataset.score);
          })
          .forEach((card) => card.parentElement.appendChild(card));

        let groupVisible = 0;
        cards.forEach((card) => {
          const match = (!q || card.dataset.search.includes(q))
            && (!subCategoryValue || card.dataset.subcategory === subCategoryValue)
            && (!statusValue || card.dataset.status === statusValue)
            && (!tagValue || card.dataset.tags.includes(tagValue));
          card.hidden = !match;
          card.style.display = match ? '' : 'none';
          if (match) {
            visible += 1;
            groupVisible += 1;
          }
        });

        group.hidden = groupVisible === 0;
        group.style.display = groupVisible === 0 ? 'none' : '';
        const count = group.querySelector('[data-group-count]');
        if (count) count.textContent = formatProjectCount(groupVisible);
      });

      empty.hidden = visible > 0;
      empty.style.display = visible > 0 ? 'none' : '';
    }

    document.querySelectorAll('[data-toggle]').forEach((button) => {
      button.addEventListener('click', () => {
        const group = button.closest('[data-group]');
        const expanded = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!expanded));
        group.classList.toggle('is-collapsed', expanded);
      });
    });

    document.querySelector('[data-reset]').addEventListener('click', () => {
      search.value = '';
      subCategory.value = '';
      status.value = '';
      tag.value = '';
      sort.value = 'score';
      applyFilters();
    });

    [search, subCategory, status, tag, sort].forEach((input) => {
      input.addEventListener('input', applyFilters);
      input.addEventListener('change', applyFilters);
    });

    const query = new URLSearchParams(window.location.search);
    if (query.get('sub')) {
      subCategory.value = query.get('sub');
    }

    applyFilters();

    async function hydrateCategoryScores() {
      const cards = Array.from(document.querySelectorAll('[data-card]'));
      const repos = cards.map((card) => card.dataset.repo).filter(Boolean);
      await window.aiLandscapeScores?.fetchScores(repos, locale);
      cards.forEach((card) => {
        const score = window.aiLandscapeScores?.getCachedScore(card.dataset.repo);
        card.dataset.score = Number.isFinite(score?.health) ? String(score.health) : '';
      });
      await window.aiLandscapeScores?.hydrateScores(document, locale);
      applyFilters();
    }

    hydrateCategoryScores();
  </script>

  <style>
    .filter-icon {
      width: 16px;
      height: 16px;
      color: var(--muted);
      flex-shrink: 0;
    }
    .search-field--filter {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .search-field--filter input {
      flex: 1;
      min-width: 0;
    }
  </style>
</BaseLayout>
