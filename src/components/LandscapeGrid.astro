---
import BaseLayout from '../layouts/BaseLayout.astro';
import LandscapeCategory from './LandscapeCategory.astro';
import LandscapeHeatmap from './LandscapeHeatmap.astro';
import LandscapeToolbar from './LandscapeToolbar.astro';
import SearchModal from './SearchModal.astro';
import {
  categoryName,
  getLandscape,
  localizedPath,
  projectDescription,
  SITE,
  statusLabel,
  subCategoryName,
  ui,
} from '../lib/landscape.mjs';

const { lang = 'en' } = Astro.props;
const copy = ui(lang);
const landscape = getLandscape();
const categories = landscape.categories
  .filter((cat) => (landscape.byCategory[cat.key] || []).length > 0)
  .sort((a, b) => (landscape.byCategory[b.key] || []).length - (landscape.byCategory[a.key] || []).length);
const badgeItems = [
  copy.scopeFeatureOpenSource,
  copy.scopeFeatureCurated,
  copy.scopeFeatureScored,
  copy.scopeFeatureNoModels,
  copy.scopeFeatureMaintained,
];
const directoryProjectStat = { value: landscape.projectCount, label: copy.projects };
const categoryHighlights = categories.slice(0, 6).map((category) => {
  const projects = landscape.byCategory[category.key] || [];
  const subcategories = (category.subcategories || [])
    .map((subcategory) => ({
      key: subcategory.key,
      name: subCategoryName(subcategory.key, lang),
      count: (landscape.bySubCategory[subcategory.key] || []).length,
    }))
    .filter((subcategory) => subcategory.count > 0)
    .sort((a, b) => b.count - a.count)
    .slice(0, 4);
  return { category, projects, subcategories };
});
const tombProjects = landscape.projects.filter((project) => ['archived', 'unavailable', 'inactive'].includes(project.status));
const tombStats = {
  total: tombProjects.length,
  unavailable: tombProjects.filter((project) => project.status === 'unavailable').length,
  archived: tombProjects.filter((project) => project.status === 'archived').length,
  inactive: tombProjects.filter((project) => project.status === 'inactive').length,
};

const searchIndex = landscape.projects.map((project) => ({
  slug: project.slug,
  name: project.name,
  repoSlug: project.repoSlug,
  statusKey: project.status,
  categoryKey: project.category,
  subCategoryKey: project.subCategory,
  tags: project.tags || [],
  description: projectDescription(project, lang),
}));
const canonical = localizedPath('/', lang);
---

<BaseLayout title={SITE.title} description={copy.metaDescription} canonical={canonical} lang={lang}>
  <main class="landscape-page" data-landscape-page>
    <section class="landscape-hero" aria-labelledby="landscape-title">
      <div class="landscape-hero__card">
        <div class="landscape-hero__text">
          <h1 id="landscape-title">{copy.landscapeTitle}</h1>
          <p class="landscape-hero__desc">{copy.heroDescription}</p>
          <div class="landscape-hero__search-wrap" data-home-search>
            <form class="landscape-hero__search" role="search" aria-label={copy.search}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
              </svg>
              <input
                id="home-search-input"
                type="search"
                placeholder={copy.homeSearchPrompt}
                autocomplete="off"
                data-home-search-input
              />
              <kbd>/</kbd>
            </form>
            <div class="landscape-hero__results" data-home-search-panel hidden>
              <div class="landscape-hero__results-list" data-home-search-results></div>
              <div class="landscape-hero__empty" data-home-search-empty hidden>{copy.searchModalNoResults}</div>
            </div>
          </div>
          <p class="landscape-hero__help">{copy.homeSearchHelp}</p>
          <div class="landscape-hero__actions">
            <a class="landscape-hero__cta landscape-hero__cta--primary" href={SITE.starRepo || SITE.repo} target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              {copy.starCta}
            </a>
            <a class="landscape-hero__cta" href={localizedPath('/submit/', lang)}>{copy.submitProject}</a>
          </div>
          <div class="landscape-hero__signals" aria-label={copy.scopeBoundary}>
            <div class="landscape-hero__signal landscape-hero__signal--projects">
              <strong>{landscape.projectCount}</strong>
              <span>{copy.projects}</span>
            </div>
            <div class="landscape-hero__signal landscape-hero__signal--categories">
              <strong>{categories.length}</strong>
              <span>{copy.categories}</span>
            </div>
            <div class="landscape-hero__signal landscape-hero__signal--tomb">
              <strong>{tombStats.total}</strong>
              <span>{copy.navTomb}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="landscape-start" aria-labelledby="landscape-start-title">
      <div class="landscape-section__head">
        <h2 id="landscape-start-title">{copy.homeStartTitle}</h2>
        <p>{copy.homeStartDescription}</p>
      </div>
      <div class="landscape-start__grid">
        <button class="landscape-start-card landscape-start-card--button landscape-start-card--search" type="button" data-focus-home-search>
          <span class="landscape-start-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          </span>
          <strong>{copy.homeStartSearchTitle}</strong>
          <span>{copy.homeStartSearchBody}</span>
        </button>
        <a class="landscape-start-card landscape-start-card--browse" href="#landscape-categories">
          <span class="landscape-start-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          </span>
          <strong>{copy.homeStartCategoriesTitle}</strong>
          <span>{copy.homeStartCategoriesBody}</span>
        </a>
        <a class="landscape-start-card landscape-start-card--method" href={localizedPath('/methodology/', lang)}>
          <span class="landscape-start-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
          </span>
          <strong>{copy.homeStartMethodologyTitle}</strong>
          <span>{copy.homeStartMethodologyBody}</span>
        </a>
        <a class="landscape-start-card landscape-start-card--tomb" href={localizedPath('/tomb/', lang)}>
          <span class="landscape-start-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M10 10h4"/></svg>
          </span>
          <strong>{copy.homeStartTombTitle}</strong>
          <span>{copy.homeStartTombBody}</span>
          <small>{tombStats.total} {copy.projects} · {tombStats.unavailable} {statusLabel('unavailable', lang)} · {tombStats.archived} {statusLabel('archived', lang)} · {tombStats.inactive} {statusLabel('inactive', lang)}</small>
        </a>
      </div>
    </section>

    <section class="landscape-categories" id="landscape-categories" aria-labelledby="landscape-categories-title">
      <div class="landscape-section__head">
        <h2 id="landscape-categories-title">{copy.homeCategoryOverviewTitle}</h2>
        <p>{copy.homeCategoryOverviewDescription}</p>
      </div>
      <div class="landscape-category-overview">
        {categoryHighlights.map(({ category, projects, subcategories }, index) => (
          <article class="landscape-category-overview__card">
            <div class="landscape-category-overview__main">
              <span class="landscape-category-overview__index">{String(index + 1).padStart(2, '0')}</span>
              <h3><a href={localizedPath(`/categories/${category.key}/`, lang)}>{categoryName(category, lang)}</a></h3>
              <span>{projects.length} {copy.projects}</span>
            </div>
            <div class="landscape-category-overview__subcats">
              {subcategories.map((subcategory) => (
                <a href={localizedPath(`/categories/${category.key}/?sub=${subcategory.key}`, lang)}>
                  {subcategory.name} <span>{subcategory.count}</span>
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <details class="landscape-directory" id="landscape-directory">
      <summary class="landscape-directory__summary">
        <h2 id="landscape-directory-title">
          <span>{copy.directoryTitle}</span>
          <span class="landscape-directory__meta" aria-label={copy.scopeBoundary}>
            <strong>{directoryProjectStat.value}</strong>
            <small>{directoryProjectStat.label}</small>
          </span>
        </h2>
        <p>{copy.homeDirectorySummary}</p>
      </summary>

      <section class="landscape-search" aria-labelledby="landscape-search-title">
        <div class="landscape-section__head">
          <h2 id="landscape-search-title">{copy.browseFilterTitle}</h2>
          <p>{copy.searchSectionDescription}</p>
        </div>
        <LandscapeToolbar lang={lang} categories={categories} />
      </section>

      <div class="landscape-category-grid" data-landscape-grid>
        {categories.map((cat, i) => <LandscapeCategory category={cat} lang={lang} index={i} />)}
      </div>

      <LandscapeHeatmap lang={lang} />
    </details>

    <section class="landscape-skill-guide" aria-labelledby="landscape-skill-guide-title">
      <div>
        <h2 id="landscape-skill-guide-title">{copy.skillGuideTitle}</h2>
        <p>{copy.skillGuideDescription}</p>
      </div>
      <div class="landscape-skill-guide__commands">
        <code class="landscape-skill-guide__cmd">npx skills add rootsongjc/ai-native-landscape --skill landscape-search</code>
        <code class="landscape-skill-guide__cmd">npx landscape-search</code>
      </div>
      <a class="landscape-skill-guide__link" href={SITE.repo} target="_blank" rel="noopener">{copy.skillGuideCta} →</a>
    </section>
  </main>

  <SearchModal searchIndex={searchIndex} lang={lang} />

  <script define:vars={{ searchIndex, lang }}>
    const grid = document.querySelector('[data-landscape-grid]');
    const heatmap = document.querySelector('[data-heatmap]');
    const categorySelect = document.querySelector('[data-landscape-category]');
    const statusSelect = document.querySelector('[data-landscape-status]');
    const sortSelect = document.querySelector('[data-landscape-sort]');
    const homeSearch = document.querySelector('[data-home-search]');
    const homeSearchInput = document.querySelector('[data-home-search-input]');
    const homeSearchPanel = document.querySelector('[data-home-search-panel]');
    const homeSearchResults = document.querySelector('[data-home-search-results]');
    const homeSearchEmpty = document.querySelector('[data-home-search-empty]');
    let homeSearchCurrentResults = [];

    function projectHref(project) {
      const prefix = lang === 'zh' ? '/zh/projects/' : '/projects/';
      return prefix + project.slug + '/';
    }

    function esc(s) {
      const d = document.createElement('div');
      d.textContent = s || '';
      return d.innerHTML;
    }

    function renderHomeSearch(query) {
      if (!homeSearchPanel || !homeSearchResults || !homeSearchEmpty) return;
      if (!query) {
        homeSearchCurrentResults = [];
        homeSearchPanel.hidden = true;
        homeSearchResults.innerHTML = '';
        homeSearchEmpty.hidden = true;
        return;
      }

      const q = query.toLowerCase();
      const results = searchIndex.filter(p => {
        const name = (p.name || '').toLowerCase();
        const desc = (p.description || '').toLowerCase();
        const tags = (p.tags || []).join(' ').toLowerCase();
        const cat = (p.categoryKey || '').toLowerCase();
        const subcat = (p.subCategoryKey || '').toLowerCase();
        return name.includes(q) || desc.includes(q) || tags.includes(q) || cat.includes(q) || subcat.includes(q);
      }).slice(0, 8);
      homeSearchCurrentResults = results;
      homeSearchPanel.hidden = false;

      if (results.length === 0) {
        homeSearchResults.innerHTML = '';
        homeSearchEmpty.hidden = false;
        return;
      }

      homeSearchEmpty.hidden = true;
      homeSearchResults.innerHTML = results.map(p => {
        const tags = (p.tags || []).slice(0, 3);
        const meta = [p.categoryKey, p.subCategoryKey].filter(Boolean).join(' / ');
        return `<a class="landscape-hero__result" href="${projectHref(p)}">
          <span class="landscape-hero__result-main">
            <span class="landscape-hero__result-name">${esc(p.name)}</span>
            ${meta ? `<span class="landscape-hero__result-category">${esc(meta)}</span>` : ''}
          </span>
          <span class="landscape-hero__result-desc">${esc((p.description || '').substring(0, 132))}</span>
          ${tags.length ? `<span class="landscape-hero__result-tags">${tags.map(tag => `<span>${esc(tag)}</span>`).join('')}</span>` : ''}
        </a>`;
      }).join('');
    }

    if (homeSearchInput) {
      homeSearch?.querySelector('form')?.addEventListener('submit', (e) => {
        e.preventDefault();
        if (homeSearchCurrentResults[0]) {
          window.location.href = projectHref(homeSearchCurrentResults[0]);
        }
      });
      homeSearchInput.addEventListener('input', () => renderHomeSearch(homeSearchInput.value.trim()));
      homeSearchInput.addEventListener('focus', () => renderHomeSearch(homeSearchInput.value.trim()));
      homeSearchInput.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          homeSearchInput.value = '';
          renderHomeSearch('');
          return;
        }
        if (e.key === 'Enter' && homeSearchCurrentResults[0]) {
          e.preventDefault();
          window.location.href = projectHref(homeSearchCurrentResults[0]);
        }
      });
    }

    document.querySelectorAll('[data-focus-home-search]').forEach(button => {
      button.addEventListener('click', () => {
        homeSearch?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        requestAnimationFrame(() => homeSearchInput?.focus());
      });
    });

    // View toggle
    const viewBtns = document.querySelectorAll('[data-view]');
    const mobileViewQuery = window.matchMedia('(max-width: 720px)');
    const requestedView = new URLSearchParams(location.search).get('view') || 'grid';
    let currentView = mobileViewQuery.matches ? 'grid' : requestedView;
    function setView(view) {
      if (mobileViewQuery.matches) view = 'grid';
      currentView = view;
      const url = new URL(location);
      if (view === 'grid') url.searchParams.delete('view');
      else url.searchParams.set('view', view);
      history.replaceState(null, '', url);
      const isGrid = view === 'grid';
      grid.style.display = isGrid ? '' : 'none';
      heatmap.style.display = isGrid ? 'none' : '';
      viewBtns.forEach(b => b.classList.toggle('landscape-toolbar__view-btn--active', b.dataset.view === view));
    }
    viewBtns.forEach(b => b.addEventListener('click', () => setView(b.dataset.view)));
    mobileViewQuery.addEventListener('change', () => setView(currentView));
    setView(currentView);

    function scoreTier(score) {
      if (!Number.isFinite(score)) return 'loading';
      if (score >= 90) return 'tier90';
      if (score >= 80) return 'tier80';
      if (score >= 70) return 'tier70';
      if (score >= 60) return 'tier60';
      return 'tierBelow';
    }

    function distributeHeatmapChips() {
      if (!window.aiLandscapeScores) return;
      const rows = heatmap.querySelectorAll('.heatmap__row');
      rows.forEach(row => {
        const staging = row.querySelector('[data-staging]');
        if (!staging) return;
        const cells = {};
        row.querySelectorAll('.heatmap__cell').forEach(cell => {
          cells[cell.dataset.tier] = cell;
        });
        const chips = staging.querySelectorAll('.heatmap__chip');
        chips.forEach(chip => {
          const repo = chip.dataset.scoreRepo;
          if (!repo) return;
          const s = window.aiLandscapeScores.getCachedScore(repo);
          const tier = scoreTier(s?.health);
          const target = cells[tier];
          if (target) target.appendChild(chip);
        });
      });
    }

    function getCardScore(card) {
      const repo = card.dataset.scoreRepo;
      if (!repo || !window.aiLandscapeScores) return -1;
      const s = window.aiLandscapeScores.getCachedScore(repo);
      return s?.health ?? -1;
    }

    function sortCardsInGrid(gridEl, mode) {
      if (mode === 'default') return;
      const cards = [...gridEl.children];
      cards.sort((a, b) => {
        if (mode === 'score') return getCardScore(b) - getCardScore(a);
        if (mode === 'name') return (a.dataset.cardName || '').localeCompare(b.dataset.cardName || '');
        if (mode === 'added') return (b.dataset.cardAdded || '').localeCompare(a.dataset.cardAdded || '');
        if (mode === 'oss-date') return (b.dataset.cardOssDate || '').localeCompare(a.dataset.cardOssDate || '');
        return 0;
      });
      cards.forEach(c => gridEl.appendChild(c));
    }

    function filterCategoryContainer(container, category, status, query, sortMode) {
      const sections = container?.querySelectorAll('.landscape-cat') || [];
      const hasActiveFilters = Boolean(query || category !== 'all' || status !== 'all');

      sections.forEach(section => {
        const categoryKey = section.dataset.category || '';
        const subcategories = section.querySelectorAll('.landscape-subcat');
        let visibleCount = 0;

        subcategories.forEach(subcategory => {
          const cards = subcategory.querySelectorAll('.landscape-card');
          const moreButton = subcategory.querySelector('[data-expand-subcategory]');
          const hiddenRest = subcategory.querySelector('[data-subcategory-rest]');
          let visibleSubcategoryCount = 0;

          cards.forEach(card => {
            const name = (card.dataset.cardName || '').toLowerCase();
            const slug = (card.dataset.cardSlug || '').toLowerCase();
            const entry = searchIndex.find(e => e.slug === slug);
            const desc = (entry?.description || '').toLowerCase();
            const repo = card.dataset.scoreRepo;
            const cardStatus = window.aiLandscapeScores?.getProjectStatus?.(repo) || '';

            const matchSearch = !query || name.includes(query) || desc.includes(query) || slug.includes(query);
            const matchCategory = category === 'all' || categoryKey === category;
            const matchStatus = status === 'all' || cardStatus === status;

            if (matchSearch && matchCategory && matchStatus) {
              card.style.display = '';
              visibleSubcategoryCount++;
              visibleCount++;
            } else {
              card.style.display = 'none';
            }
          });

          if (hiddenRest) {
            if (hasActiveFilters) {
              hiddenRest.hidden = false;
            } else {
              hiddenRest.hidden = moreButton?.dataset.expanded !== 'true';
            }
          }

          if (moreButton) {
            moreButton.style.display = hasActiveFilters || visibleSubcategoryCount === 0 ? 'none' : '';
          }

          subcategory.style.display = visibleSubcategoryCount === 0 ? 'none' : '';

          if (sortMode !== 'default') {
            subcategory.querySelectorAll('.landscape-subcat__grid').forEach(g => sortCardsInGrid(g, sortMode));
          }
        });

        section.style.display = visibleCount === 0 ? 'none' : '';
      });
    }

    function applyFilters() {
      const category = categorySelect?.value || 'all';
      const status = statusSelect?.value || 'all';
      const sortMode = sortSelect?.value || 'default';

      filterCategoryContainer(grid, category, status, '', sortMode);

      updateAllTooltipOffsets();
    }

    if (categorySelect) categorySelect.addEventListener('change', applyFilters);
    if (statusSelect) statusSelect.addEventListener('change', applyFilters);
    if (sortSelect) sortSelect.addEventListener('change', applyFilters);

    function updateTooltipOffset(card) {
      const tooltip = card?.querySelector('.landscape-card__tooltip');
      if (!tooltip) return;

      card.style.setProperty('--tooltip-offset', '0px');
      const viewportPadding = 12;

      let offset = 0;
      for (let index = 0; index < 2; index += 1) {
        const rect = tooltip.getBoundingClientRect();

        if (rect.left < viewportPadding) {
          offset += viewportPadding - rect.left;
        } else if (rect.right > window.innerWidth - viewportPadding) {
          offset += window.innerWidth - viewportPadding - rect.right;
        } else {
          break;
        }

        card.style.setProperty('--tooltip-offset', `${Math.round(offset)}px`);
      }

      card.style.setProperty('--tooltip-offset', `${Math.round(offset)}px`);
    }

    function updateAllTooltipOffsets() {
      document.querySelectorAll('.landscape-card').forEach(card => updateTooltipOffset(card));
    }

    updateAllTooltipOffsets();
    window.addEventListener('resize', updateAllTooltipOffsets);

    function hydrateTooltipStatuses() {
      if (!window.aiLandscapeScores) return;
      const cards = document.querySelectorAll('.landscape-card[data-score-repo]');
      cards.forEach(card => {
        const repo = card.dataset.scoreRepo;
        if (!repo) return;
        const scores = window.aiLandscapeScores.getCachedScore(repo);
        const tip = card.querySelector('[data-tooltip-status]');
        if (!tip) return;
        tip.textContent = window.aiLandscapeScores.scoreLabel(scores?.health);
      });
    }

    window.addEventListener('ai-landscape:scores-ready', () => {
      hydrateTooltipStatuses();
      distributeHeatmapChips();
    });
    const scoreCheck = setInterval(() => {
      if (window.aiLandscapeScores?.getCachedScore(searchIndex[0]?.repoSlug)) {
        hydrateTooltipStatuses();
        distributeHeatmapChips();
        clearInterval(scoreCheck);
      }
    }, 500);
    setTimeout(() => clearInterval(scoreCheck), 10000);

  </script>
</BaseLayout>

<style>
  .landscape-page {
    padding: 20px 0 48px;
    display: grid;
    gap: 28px;
  }

  .landscape-hero,
  .landscape-search,
  .landscape-directory {
    display: grid;
    gap: 16px;
  }

  /* Hero card with border */
  .landscape-hero__card {
    display: flex;
    align-items: center;
    gap: 40px;
    padding: 28px 32px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .landscape-hero__text {
    display: grid;
    gap: 14px;
    flex: 1 1 auto;
    min-width: 0;
  }

  .landscape-hero h1 {
    margin: 0;
    font-size: clamp(1.5rem, 2.8vw, 2.2rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    font-weight: 800;
  }

  .landscape-hero__desc {
    margin: 0;
    color: var(--muted);
    font-size: clamp(0.92rem, 1.2vw, 1.05rem);
    line-height: 1.6;
    max-width: 520px;
  }

  .landscape-hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .landscape-hero__badges span {
    display: inline-flex;
    align-items: center;
    min-height: 26px;
    padding: 3px 10px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface-soft);
    color: var(--muted);
    font-size: 0.74rem;
    font-weight: 700;
    line-height: 1;
    transition: border-color 0.15s, color 0.15s;
  }

  .landscape-hero__badges span:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Constellation visual */
  .landscape-hero__visual {
    flex: 0 0 260px;
    min-width: 200px;
  }

  .landscape-hero__constellation {
    width: 100%;
    height: auto;
  }

  /* Node float animation */
  @keyframes lc-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  .lc-node { animation: lc-float 3s ease-in-out infinite; }
  .lc-node--1 { animation-delay: 0s; }
  .lc-node--2 { animation-delay: 0.3s; }
  .lc-node--3 { animation-delay: 0.6s; }
  .lc-node--4 { animation-delay: 0.9s; }
  .lc-node--5 { animation-delay: 1.2s; }
  .lc-node--6 { animation-delay: 0.15s; }
  .lc-node--7 { animation-delay: 0.45s; }
  .lc-node--8 { animation-delay: 0.75s; }
  .lc-node--9 { animation-delay: 1.05s; }
  .lc-node--10 { animation-delay: 0.5s; }
  .lc-node--11 { animation-delay: 0.8s; }
  .lc-node--12 { animation-delay: 1.1s; }

  /* Line fade animation */
  @keyframes lc-line-fade {
    0%, 100% { opacity: 0.15; }
    50% { opacity: 0.35; }
  }

  .lc-line { animation: lc-line-fade 4s ease-in-out infinite; }
  .lc-line:nth-child(odd) { animation-delay: 0.5s; }

  /* Pulse ring animation */
  @keyframes lc-pulse-ring {
    0% { r: 8; opacity: 0.6; }
    100% { r: 20; opacity: 0; }
  }

  .lc-pulse { animation: lc-pulse-ring 2.5s ease-out infinite; }
  .lc-pulse:nth-of-type(2) { animation-delay: 0.8s; }
  .lc-pulse:nth-of-type(3) { animation-delay: 1.6s; }

  /* Skill guide — compact inline banner */
  .landscape-skill-guide {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .landscape-skill-guide__title {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text);
  }

  .landscape-skill-guide__cmd {
    padding: 3px 10px;
    border: 1px solid rgba(10, 132, 255, 0.2);
    border-radius: 4px;
    background: rgba(10, 132, 255, 0.05);
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 0.74rem;
    font-weight: 600;
    color: var(--accent);
    white-space: nowrap;
  }

  html[data-theme='dark'] .landscape-skill-guide__cmd {
    border-color: rgba(110, 168, 255, 0.2);
    background: rgba(110, 168, 255, 0.08);
  }

  .landscape-skill-guide__sep {
