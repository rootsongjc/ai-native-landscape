    height: 24px;
    color: var(--accent);
  }

  .landscape-hero__search input {
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--muted);
    font-size: clamp(1rem, 1.8vw, 1.22rem);
