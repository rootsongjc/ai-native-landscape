    font-size: clamp(1rem, 1.7vw, 1.22rem);
  }

  .landscape-hero__search {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 12px;
    width: min(100%, 720px);
