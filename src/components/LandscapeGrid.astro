  /* Homepage IA redesign */
  .landscape-page {
    gap: 30px;
  }

  .landscape-start,
  .landscape-categories,
  .landscape-directory,
  .landscape-skill-guide {
    display: grid;
    gap: 16px;
  }

  .landscape-hero__card {
    justify-content: center;
    min-height: min(560px, calc(100vh - 150px));
