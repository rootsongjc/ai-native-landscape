---
import BaseLayout from '../layouts/BaseLayout.astro';
import LandscapeCategory from './LandscapeCategory.astro';
import LandscapeHeatmap from './LandscapeHeatmap.astro';
import LandscapeToolbar from './LandscapeToolbar.astro';
import SearchModal from './SearchModal.astro';
import {
  getLandscape,
  localizedPath,
  projectDescription,
  SITE,
  ui,
} from '../lib/landscape.mjs';

const { lang = 'en' } = Astro.props;
const copy = ui(lang);
const landscape = getLandscape();
const categories = landscape.categories
  .filter((cat) => (landscape.byCategory[cat.key] || []).length > 0)
  .sort((a, b) => (landscape.byCategory[b.key] || []).length - (landscape.byCategory[a.key] || []).length);
const badgeItems = [
  copy.scopeFeatureOpenSource,
  copy.scopeFeatureCurated,
  copy.scopeFeatureScored,
  copy.scopeFeatureNoModels,
  copy.scopeFeatureMaintained,
];
const directoryProjectStat = { value: landscape.projectCount, label: copy.projects };

const searchIndex = landscape.projects.map((project) => ({
  slug: project.slug,
  name: project.name,
  repoSlug: project.repoSlug,
  statusKey: project.status,
  categoryKey: project.category,
  subCategoryKey: project.subCategory,
  tags: project.tags || [],
  description: projectDescription(project, lang),
}));
const canonical = localizedPath('/', lang);
---

<BaseLayout title={SITE.title} description={copy.metaDescription} canonical={canonical} lang={lang}>
  <main class="landscape-page" data-landscape-page>
    <section class="landscape-hero" aria-labelledby="landscape-title">
      <div class="landscape-hero__card">
        <div class="landscape-hero__text">
          <h1 id="landscape-title">{copy.landscapeTitle}</h1>
          <p class="landscape-hero__desc">{copy.heroDescription}</p>
          <div class="landscape-hero__badges" aria-label={copy.scopeBoundary}>
            {badgeItems.map((item) => (
              <span>{item}</span>
            ))}
          </div>
        </div>
        <div class="landscape-hero__visual" aria-hidden="true">
          <svg class="landscape-hero__constellation" viewBox="0 0 320 200" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle class="lc-node lc-node--1" cx="40" cy="60" r="6" fill="var(--accent)" opacity="0.9"/>
            <circle class="lc-node lc-node--2" cx="100" cy="30" r="5" fill="var(--accent)" opacity="0.7"/>
            <circle class="lc-node lc-node--3" cx="160" cy="80" r="8" fill="var(--accent)" opacity="0.9"/>
            <circle class="lc-node lc-node--4" cx="220" cy="40" r="5" fill="var(--accent)" opacity="0.6"/>
            <circle class="lc-node lc-node--5" cx="280" cy="70" r="6" fill="var(--accent)" opacity="0.8"/>
            <circle class="lc-node lc-node--6" cx="70" cy="130" r="5" fill="var(--accent)" opacity="0.7"/>
            <circle class="lc-node lc-node--7" cx="130" cy="150" r="7" fill="var(--accent)" opacity="0.9"/>
            <circle class="lc-node lc-node--8" cx="200" cy="140" r="5" fill="var(--accent)" opacity="0.6"/>
            <circle class="lc-node lc-node--9" cx="260" cy="160" r="6" fill="var(--accent)" opacity="0.8"/>
            <circle class="lc-node lc-node--10" cx="40" cy="170" r="4" fill="var(--accent)" opacity="0.5"/>
            <circle class="lc-node lc-node--11" cx="300" cy="130" r="4" fill="var(--accent)" opacity="0.6"/>
            <circle class="lc-node lc-node--12" cx="160" cy="25" r="4" fill="var(--accent)" opacity="0.5"/>
            <line class="lc-line" x1="40" y1="60" x2="100" y2="30" stroke="var(--accent)" stroke-width="0.8" opacity="0.2"/>
            <line class="lc-line" x1="100" y1="30" x2="160" y2="80" stroke="var(--accent)" stroke-width="0.8" opacity="0.2"/>
            <line class="lc-line" x1="160" y1="80" x2="220" y2="40" stroke="var(--accent)" stroke-width="0.8" opacity="0.2"/>
            <line class="lc-line" x1="220" y1="40" x2="280" y2="70" stroke="var(--accent)" stroke-width="0.8" opacity="0.2"/>
            <line class="lc-line" x1="40" y1="60" x2="70" y2="130" stroke="var(--accent)" stroke-width="0.8" opacity="0.15"/>
            <line class="lc-line" x1="70" y1="130" x2="130" y2="150" stroke="var(--accent)" stroke-width="0.8" opacity="0.2"/>
            <line class="lc-line" x1="130" y1="150" x2="200" y2="140" stroke="var(--accent)" stroke-width="0.8" opacity="0.2"/>
            <line class="lc-line" x1="200" y1="140" x2="260" y2="160" stroke="var(--accent)" stroke-width="0.8" opacity="0.2"/>
            <line class="lc-line" x1="160" y1="80" x2="130" y2="150" stroke="var(--accent)" stroke-width="0.8" opacity="0.15"/>
            <line class="lc-line" x1="280" y1="70" x2="300" y2="130" stroke="var(--accent)" stroke-width="0.8" opacity="0.15"/>
            <line class="lc-line" x1="260" y1="160" x2="300" y2="130" stroke="var(--accent)" stroke-width="0.8" opacity="0.15"/>
            <line class="lc-line" x1="40" y1="170" x2="70" y2="130" stroke="var(--accent)" stroke-width="0.8" opacity="0.15"/>
            <line class="lc-line" x1="160" y1="25" x2="100" y2="30" stroke="var(--accent)" stroke-width="0.8" opacity="0.15"/>
            <line class="lc-line" x1="160" y1="25" x2="220" y2="40" stroke="var(--accent)" stroke-width="0.8" opacity="0.15"/>
            <circle class="lc-pulse" cx="160" cy="80" r="8" stroke="var(--accent)" stroke-width="1" fill="none" opacity="0"/>
            <circle class="lc-pulse" cx="130" cy="150" r="7" stroke="var(--accent)" stroke-width="1" fill="none" opacity="0"/>
            <circle class="lc-pulse" cx="280" cy="70" r="6" stroke="var(--accent)" stroke-width="1" fill="none" opacity="0"/>
          </svg>
        </div>
      </div>
    </section>

    <div class="landscape-skill-guide" aria-label={copy.skillGuideTitle}>
      <span class="landscape-skill-guide__title">{copy.skillGuideTitle}</span>
      <code class="landscape-skill-guide__cmd">npx skills add rootsongjc/ai-native-landscape --skill landscape-search</code>
      <span class="landscape-skill-guide__sep">|</span>
      <code class="landscape-skill-guide__cmd">npx landscape-search</code>
      <a class="landscape-skill-guide__link" href={SITE.repo} target="_blank" rel="noopener">{copy.skillGuideCta} →</a>
    </div>

    <section class="landscape-search" aria-labelledby="landscape-search-title">
      <div class="landscape-section__head">
        <h2 id="landscape-search-title">{copy.browseFilterTitle}</h2>
        <p>{copy.searchSectionDescription}</p>
      </div>
      <LandscapeToolbar lang={lang} categories={categories} />
    </section>

    <section class="landscape-directory" id="landscape-directory" aria-labelledby="landscape-directory-title">
      <div class="landscape-section__head landscape-directory__heading">
        <h2 id="landscape-directory-title">
          <span>{copy.directoryTitle}</span>
          <span class="landscape-directory__meta" aria-label={copy.scopeBoundary}>
            <strong>{directoryProjectStat.value}</strong>
            <small>{directoryProjectStat.label}</small>
          </span>
        </h2>
        <p>{copy.directoryDescription}</p>
      </div>

      <div class="landscape-category-grid" data-landscape-grid>
        {categories.map((cat, i) => (
          <LandscapeCategory category={cat} lang={lang} index={i} />
        ))}
      </div>

      <LandscapeHeatmap lang={lang} />
    </section>
  </main>

  <SearchModal searchIndex={searchIndex} lang={lang} />

  <script define:vars={{ searchIndex, lang }}>
    const grid = document.querySelector('[data-landscape-grid]');
    const heatmap = document.querySelector('[data-heatmap]');
    const categorySelect = document.querySelector('[data-landscape-category]');
    const statusSelect = document.querySelector('[data-landscape-status]');
    const sortSelect = document.querySelector('[data-landscape-sort]');

    // View toggle
    const viewBtns = document.querySelectorAll('[data-view]');
    const mobileViewQuery = window.matchMedia('(max-width: 720px)');
    const requestedView = new URLSearchParams(location.search).get('view') || 'grid';
    let currentView = mobileViewQuery.matches ? 'grid' : requestedView;
    function setView(view) {
      if (mobileViewQuery.matches) view = 'grid';
      currentView = view;
      const url = new URL(location);
      if (view === 'grid') url.searchParams.delete('view');
      else url.searchParams.set('view', view);
      history.replaceState(null, '', url);
      const isGrid = view === 'grid';
      grid.style.display = isGrid ? '' : 'none';
      heatmap.style.display = isGrid ? 'none' : '';
      viewBtns.forEach(b => b.classList.toggle('landscape-toolbar__view-btn--active', b.dataset.view === view));
    }
    viewBtns.forEach(b => b.addEventListener('click', () => setView(b.dataset.view)));
    mobileViewQuery.addEventListener('change', () => setView(currentView));
    setView(currentView);

    function scoreTier(score) {
      if (!Number.isFinite(score)) return 'loading';
      if (score >= 90) return 'tier90';
      if (score >= 80) return 'tier80';
      if (score >= 70) return 'tier70';
      if (score >= 60) return 'tier60';
      return 'tierBelow';
    }

    function distributeHeatmapChips() {
      if (!window.aiLandscapeScores) return;
      const rows = heatmap.querySelectorAll('.heatmap__row');
      rows.forEach(row => {
        const staging = row.querySelector('[data-staging]');
        if (!staging) return;
        const cells = {};
        row.querySelectorAll('.heatmap__cell').forEach(cell => {
          cells[cell.dataset.tier] = cell;
        });
        const chips = staging.querySelectorAll('.heatmap__chip');
        chips.forEach(chip => {
          const repo = chip.dataset.scoreRepo;
          if (!repo) return;
          const s = window.aiLandscapeScores.getCachedScore(repo);
          const tier = scoreTier(s?.health);
          const target = cells[tier];
          if (target) target.appendChild(chip);
        });
      });
    }

    function getCardScore(card) {
      const repo = card.dataset.scoreRepo;
      if (!repo || !window.aiLandscapeScores) return -1;
      const s = window.aiLandscapeScores.getCachedScore(repo);
      return s?.health ?? -1;
    }

    function sortCardsInGrid(gridEl, mode) {
      if (mode === 'default') return;
      const cards = [...gridEl.children];
      cards.sort((a, b) => {
        if (mode === 'score') return getCardScore(b) - getCardScore(a);
        if (mode === 'name') return (a.dataset.cardName || '').localeCompare(b.dataset.cardName || '');
        if (mode === 'added') return (b.dataset.cardAdded || '').localeCompare(a.dataset.cardAdded || '');
        if (mode === 'oss-date') return (b.dataset.cardOssDate || '').localeCompare(a.dataset.cardOssDate || '');
        return 0;
      });
      cards.forEach(c => gridEl.appendChild(c));
    }

    function filterCategoryContainer(container, category, status, query, sortMode) {
      const sections = container?.querySelectorAll('.landscape-cat') || [];
      const hasActiveFilters = Boolean(query || category !== 'all' || status !== 'all');

      sections.forEach(section => {
        const categoryKey = section.dataset.category || '';
        const subcategories = section.querySelectorAll('.landscape-subcat');
        let visibleCount = 0;

        subcategories.forEach(subcategory => {
          const cards = subcategory.querySelectorAll('.landscape-card');
          const moreButton = subcategory.querySelector('[data-expand-subcategory]');
          const hiddenRest = subcategory.querySelector('[data-subcategory-rest]');
          let visibleSubcategoryCount = 0;

          cards.forEach(card => {
            const name = (card.dataset.cardName || '').toLowerCase();
            const slug = (card.dataset.cardSlug || '').toLowerCase();
            const entry = searchIndex.find(e => e.slug === slug);
            const desc = (entry?.description || '').toLowerCase();
            const repo = card.dataset.scoreRepo;
            const cardStatus = window.aiLandscapeScores?.getProjectStatus?.(repo) || '';

            const matchSearch = !query || name.includes(query) || desc.includes(query) || slug.includes(query);
            const matchCategory = category === 'all' || categoryKey === category;
            const matchStatus = status === 'all' || cardStatus === status;

            if (matchSearch && matchCategory && matchStatus) {
              card.style.display = '';
              visibleSubcategoryCount++;
              visibleCount++;
            } else {
              card.style.display = 'none';
            }
          });

          if (hiddenRest) {
            if (hasActiveFilters) {
              hiddenRest.hidden = false;
            } else {
              hiddenRest.hidden = moreButton?.dataset.expanded !== 'true';
            }
          }

          if (moreButton) {
            moreButton.style.display = hasActiveFilters || visibleSubcategoryCount === 0 ? 'none' : '';
          }

          subcategory.style.display = visibleSubcategoryCount === 0 ? 'none' : '';

          if (sortMode !== 'default') {
            subcategory.querySelectorAll('.landscape-subcat__grid').forEach(g => sortCardsInGrid(g, sortMode));
          }
        });

        section.style.display = visibleCount === 0 ? 'none' : '';
      });
    }

    function applyFilters() {
      const category = categorySelect?.value || 'all';
      const status = statusSelect?.value || 'all';
      const sortMode = sortSelect?.value || 'default';

      filterCategoryContainer(grid, category, status, '', sortMode);

      updateAllTooltipOffsets();
    }

    if (categorySelect) categorySelect.addEventListener('change', applyFilters);
    if (statusSelect) statusSelect.addEventListener('change', applyFilters);
    if (sortSelect) sortSelect.addEventListener('change', applyFilters);

    function updateTooltipOffset(card) {
      const tooltip = card?.querySelector('.landscape-card__tooltip');
      if (!tooltip) return;

      card.style.setProperty('--tooltip-offset', '0px');
      const viewportPadding = 12;

      let offset = 0;
      for (let index = 0; index < 2; index += 1) {
        const rect = tooltip.getBoundingClientRect();

        if (rect.left < viewportPadding) {
          offset += viewportPadding - rect.left;
        } else if (rect.right > window.innerWidth - viewportPadding) {
          offset += window.innerWidth - viewportPadding - rect.right;
        } else {
          break;
        }

        card.style.setProperty('--tooltip-offset', `${Math.round(offset)}px`);
      }

      card.style.setProperty('--tooltip-offset', `${Math.round(offset)}px`);
    }

    function updateAllTooltipOffsets() {
      document.querySelectorAll('.landscape-card').forEach(card => updateTooltipOffset(card));
    }

    updateAllTooltipOffsets();
    window.addEventListener('resize', updateAllTooltipOffsets);

    function hydrateTooltipStatuses() {
      if (!window.aiLandscapeScores) return;
      const cards = document.querySelectorAll('.landscape-card[data-score-repo]');
      cards.forEach(card => {
        const repo = card.dataset.scoreRepo;
        if (!repo) return;
        const scores = window.aiLandscapeScores.getCachedScore(repo);
        const tip = card.querySelector('[data-tooltip-status]');
        if (!tip) return;
        tip.textContent = window.aiLandscapeScores.scoreLabel(scores?.health);
      });
    }

    window.addEventListener('ai-landscape:scores-ready', () => {
      hydrateTooltipStatuses();
      distributeHeatmapChips();
    });
    const scoreCheck = setInterval(() => {
      if (window.aiLandscapeScores?.getCachedScore(searchIndex[0]?.repoSlug)) {
        hydrateTooltipStatuses();
        distributeHeatmapChips();
        clearInterval(scoreCheck);
      }
    }, 500);
    setTimeout(() => clearInterval(scoreCheck), 10000);

  </script>
</BaseLayout>

<style>
  .landscape-page {
    padding: 20px 0 48px;
    display: grid;
    gap: 28px;
  }

  .landscape-hero,
  .landscape-search,
  .landscape-directory {
    display: grid;
    gap: 16px;
  }

  /* Hero card with border */
  .landscape-hero__card {
    display: flex;
    align-items: center;
    gap: 40px;
    padding: 28px 32px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .landscape-hero__text {
    display: grid;
    gap: 14px;
    flex: 1 1 auto;
    min-width: 0;
  }

  .landscape-hero h1 {
    margin: 0;
    font-size: clamp(1.5rem, 2.8vw, 2.2rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    font-weight: 800;
  }

  .landscape-hero__desc {
    margin: 0;
    color: var(--muted);
    font-size: clamp(0.92rem, 1.2vw, 1.05rem);
    line-height: 1.6;
    max-width: 520px;
  }

  .landscape-hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .landscape-hero__badges span {
    display: inline-flex;
    align-items: center;
    min-height: 26px;
    padding: 3px 10px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface-soft);
    color: var(--muted);
    font-size: 0.74rem;
    font-weight: 700;
    line-height: 1;
    transition: border-color 0.15s, color 0.15s;
  }

  .landscape-hero__badges span:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Constellation visual */
  .landscape-hero__visual {
    flex: 0 0 260px;
    min-width: 200px;
  }

  .landscape-hero__constellation {
    width: 100%;
    height: auto;
  }

  /* Node float animation */
  @keyframes lc-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  .lc-node { animation: lc-float 3s ease-in-out infinite; }
  .lc-node--1 { animation-delay: 0s; }
  .lc-node--2 { animation-delay: 0.3s; }
  .lc-node--3 { animation-delay: 0.6s; }
  .lc-node--4 { animation-delay: 0.9s; }
  .lc-node--5 { animation-delay: 1.2s; }
  .lc-node--6 { animation-delay: 0.15s; }
  .lc-node--7 { animation-delay: 0.45s; }
  .lc-node--8 { animation-delay: 0.75s; }
  .lc-node--9 { animation-delay: 1.05s; }
  .lc-node--10 { animation-delay: 0.5s; }
  .lc-node--11 { animation-delay: 0.8s; }
  .lc-node--12 { animation-delay: 1.1s; }

  /* Line fade animation */
  @keyframes lc-line-fade {
    0%, 100% { opacity: 0.15; }
    50% { opacity: 0.35; }
  }

  .lc-line { animation: lc-line-fade 4s ease-in-out infinite; }
  .lc-line:nth-child(odd) { animation-delay: 0.5s; }

  /* Pulse ring animation */
  @keyframes lc-pulse-ring {
    0% { r: 8; opacity: 0.6; }
    100% { r: 20; opacity: 0; }
  }

  .lc-pulse { animation: lc-pulse-ring 2.5s ease-out infinite; }
  .lc-pulse:nth-of-type(2) { animation-delay: 0.8s; }
  .lc-pulse:nth-of-type(3) { animation-delay: 1.6s; }

  /* Skill guide — compact inline banner */
  .landscape-skill-guide {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .landscape-skill-guide__title {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text);
  }

  .landscape-skill-guide__cmd {
    padding: 3px 10px;
    border: 1px solid rgba(10, 132, 255, 0.2);
    border-radius: 4px;
    background: rgba(10, 132, 255, 0.05);
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 0.74rem;
    font-weight: 600;
    color: var(--accent);
    white-space: nowrap;
  }

  html[data-theme='dark'] .landscape-skill-guide__cmd {
    border-color: rgba(110, 168, 255, 0.2);
    background: rgba(110, 168, 255, 0.08);
  }

  .landscape-skill-guide__sep {
    color: var(--border);
    font-weight: 300;
  }

  .landscape-skill-guide__link {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    margin-left: auto;
  }

  .landscape-skill-guide__link:hover {
    text-decoration: underline;
  }

  @media (max-width: 720px) {
    .landscape-skill-guide__cmd {
      font-size: 0.68rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lc-node, .lc-line, .lc-pulse { animation: none; }
  }

  @media (max-width: 720px) {
    .landscape-hero__card {
      flex-direction: column;
      gap: 20px;
      padding: 20px;
    }
    .landscape-hero__visual {
      flex: 0 0 auto;
      width: 100%;
      max-width: 280px;
      align-self: center;
    }
  }

  .landscape-section__head {
    display: grid;
    gap: 6px;
    max-width: 720px;
  }

  .landscape-section__head h2 {
    margin: 0;
    font-size: 1.36rem;
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  .landscape-section__head p {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .landscape-directory__meta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 28px;
    margin-left: 10px;
    padding: 4px 10px;
    border: 1px solid rgba(10, 132, 255, 0.12);
    border-radius: 999px;
    background: rgba(10, 132, 255, 0.04);
    color: var(--muted);
    vertical-align: middle;
  }

  .landscape-directory__heading h2 {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
  }

  .landscape-directory__meta strong {
    color: var(--text);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .landscape-directory__meta small {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  html[data-theme='dark'] .landscape-directory__meta {
    border-color: rgba(110,168,255,0.14);
    background: rgba(110,168,255,0.07);
  }

  .landscape-category-grid,
  .landscape-grid {
    display: grid;
    gap: 32px;
  }

  @media (max-width: 720px) {
    .landscape-page {
      gap: 24px;
    }

    .landscape-hero {
      padding-top: 10px;
    }

    .landscape-hero__badges {
      gap: 7px;
    }

    .landscape-hero__badges span {
      min-height: 32px;
      padding: 5px 11px;
      font-size: 0.76rem;
    }
  }

</style>
