      flex: 1 1 150px;
    }

    .landscape-skill-guide__cmd {
      max-width: 100%;
      white-space: normal;
      overflow-wrap: anywhere;
    }
  }

  /* Visual focus refinement */
  .landscape-hero__card {
    position: relative;
    overflow: hidden;
    border-color: color-mix(in srgb, var(--accent) 22%, var(--border));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface-soft) 76%, transparent), var(--surface) 72%),
      radial-gradient(circle at 50% 0%, rgba(10, 132, 255, 0.18), transparent 34%);
  }

  .landscape-hero__text {
    position: relative;
    z-index: 1;
  }

  .landscape-hero__desc {
    max-width: 650px;
