---
import LandscapeCard from './LandscapeCard.astro';
import {
  categoryName,
  getLandscape,
  localizedPath,
  subCategoryName,
} from '../lib/landscape.mjs';

const { category, lang = 'en', index = 0 } = Astro.props;
const landscape = getLandscape();
const projects = landscape.byCategory[category.key] || [];
const subCategories = category.subcategories || [];
const name = categoryName(category, lang);
const categoryHref = localizedPath(`/categories/${category.key}/`, lang);
const INITIAL_COUNT = 16;

const categoryIcons = {
  'agents': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a3 3 0 00-3 3v1a3 3 0 006 0V5a3 3 0 00-3-3z"/><path d="M19 13v-1a7 7 0 00-14 0v1"/><circle cx="12" cy="17" r="3"/><path d="M9 17H4M20 17h-5"/></svg>',
  'models-modalities': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>',
  'rag-knowledge': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>',
  'inference-serving': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6M9 13h6M9 17h4"/></svg>',
  'coding-devtools': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
  'training-optimization': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10M18 20V4M6 20v-4"/></svg>',
  'evaluation-observability': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>',
  'applications-products': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>',
  'platform-infra': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10A15.3 15.3 0 0112 2z"/></svg>',
};
const catIcon = categoryIcons[category.key] || '';

const palette = [
  { accent: '#3b82f6', bg: 'rgba(59,130,246,0.04)', bgDark: 'rgba(59,130,246,0.08)', header: 'rgba(59,130,246,0.10)', headerDark: 'rgba(59,130,246,0.22)' },
  { accent: '#8b5cf6', bg: 'rgba(139,92,246,0.04)', bgDark: 'rgba(139,92,246,0.08)', header: 'rgba(139,92,246,0.10)', headerDark: 'rgba(139,92,246,0.22)' },
  { accent: '#10b981', bg: 'rgba(16,185,129,0.04)', bgDark: 'rgba(16,185,129,0.08)', header: 'rgba(16,185,129,0.10)', headerDark: 'rgba(16,185,129,0.22)' },
  { accent: '#f59e0b', bg: 'rgba(245,158,11,0.04)', bgDark: 'rgba(245,158,11,0.08)', header: 'rgba(245,158,11,0.10)', headerDark: 'rgba(245,158,11,0.22)' },
  { accent: '#ef4444', bg: 'rgba(239,68,68,0.04)', bgDark: 'rgba(239,68,68,0.08)', header: 'rgba(239,68,68,0.10)', headerDark: 'rgba(239,68,68,0.22)' },
  { accent: '#06b6d4', bg: 'rgba(6,182,212,0.04)', bgDark: 'rgba(6,182,212,0.08)', header: 'rgba(6,182,212,0.10)', headerDark: 'rgba(6,182,212,0.22)' },
  { accent: '#ec4899', bg: 'rgba(236,72,153,0.04)', bgDark: 'rgba(236,72,153,0.08)', header: 'rgba(236,72,153,0.10)', headerDark: 'rgba(236,72,153,0.22)' },
  { accent: '#14b8a6', bg: 'rgba(20,184,166,0.04)', bgDark: 'rgba(20,184,166,0.08)', header: 'rgba(20,184,166,0.10)', headerDark: 'rgba(20,184,166,0.22)' },
  { accent: '#f97316', bg: 'rgba(249,115,22,0.04)', bgDark: 'rgba(249,115,22,0.08)', header: 'rgba(249,115,22,0.10)', headerDark: 'rgba(249,115,22,0.22)' },
  { accent: '#6366f1', bg: 'rgba(99,102,241,0.04)', bgDark: 'rgba(99,102,241,0.08)', header: 'rgba(99,102,241,0.10)', headerDark: 'rgba(99,102,241,0.22)' },
];
const color = palette[index % palette.length];
---

<section
  class="landscape-cat"
  data-category={category.key}
  style={`--cat-accent: ${color.accent}; --cat-bg: ${color.bg}; --cat-bg-dark: ${color.bgDark}; --cat-header: ${color.header}; --cat-header-dark: ${color.headerDark};`}
>
  <div class="landscape-cat__header">
    <a class="landscape-cat__title" href={categoryHref}>
      <span class="landscape-cat__icon" style={`background: ${color.accent};`} set:html={catIcon} />
      {name}
    </a>
    <span class="landscape-cat__meta">{subCategories.map((sc) => subCategoryName(sc.key, lang)).join(' · ')}</span>
    <span class="landscape-cat__count" style={`background: ${color.accent};`}>{projects.length}</span>
    <button
      class="landscape-cat__toggle"
      data-cat-toggle
      data-label-expanded={lang === 'zh' ? '收起分类' : 'Collapse category'}
      data-label-collapsed={lang === 'zh' ? '展开分类' : 'Expand category'}
      aria-label={lang === 'zh' ? '收起分类' : 'Collapse category'}
      aria-expanded="true"
      title={lang === 'zh' ? '收起分类' : 'Collapse category'}
    >
      <span class="landscape-cat__toggle-label">{lang === 'zh' ? '收起分类' : 'Collapse category'}</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
    </button>
  </div>

  <div class="landscape-cat__body" data-cat-body>
  {subCategories.map((sc) => {
    const scProjects = (landscape.bySubCategory[sc.key] || []);
    if (scProjects.length === 0) return null;
    const scName = subCategoryName(sc.key, lang);
    const initial = scProjects.slice(0, INITIAL_COUNT);
    const rest = scProjects.slice(INITIAL_COUNT);
    return (
      <div class="landscape-subcat" data-subcategory={sc.key}>
        <span class="landscape-subcat__label" style={`color: var(--cat-accent);`}>{scName}</span>
        <div class="landscape-subcat__grid">
          {initial.map((p) => <LandscapeCard project={p} lang={lang} />)}
        </div>
        {rest.length > 0 && (
          <button
            class="landscape-subcat__more"
            data-expand-subcategory={sc.key}
            data-expanded="false"
          >
            +{rest.length} {lang === 'zh' ? '更多' : 'more'}
          </button>
        )}
        <div class="landscape-subcat__hidden" data-subcategory-rest={sc.key} hidden>
          <div class="landscape-subcat__grid">
            {rest.map((p) => <LandscapeCard project={p} lang={lang} />)}
          </div>
        </div>
      </div>
    );
  })}
  </div>
</section>

<style>
  .landscape-cat {
    border: 1px solid var(--border);
    border-left: 4px solid var(--cat-accent);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
    padding: 0;
    transition: box-shadow 0.25s, transform 0.25s;
    overflow: visible;
    position: relative;
    z-index: 0;
  }
  .landscape-cat:hover,
  .landscape-cat:focus-within {
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    transform: translateY(-1px);
    z-index: 20;
  }
  html[data-theme='dark'] .landscape-cat:hover,
  html[data-theme='dark'] .landscape-cat:focus-within {
    box-shadow: 0 8px 30px rgba(0,0,0,0.35);
  }

  .landscape-cat__header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    background: var(--cat-header);
    border-bottom: 1px solid var(--border);
  }
  html[data-theme='dark'] .landscape-cat__header {
    background: var(--cat-header-dark);
  }

  .landscape-cat__title {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s;
    padding: 2px 0;
    border-radius: 4px;
  }
  .landscape-cat__title:hover {
    color: var(--cat-accent);
  }

  .landscape-cat__toggle {
    padding: 4px;
    border: none;
    background: none;
    color: var(--muted);
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .landscape-cat__toggle-label {
    display: none;
  }

  .landscape-cat__toggle:hover {
    background: var(--accent-soft);
    color: var(--cat-accent);
  }
  .landscape-cat__toggle svg {
    transition: transform 0.25s;
  }
  .landscape-cat[data-collapsed] .landscape-cat__toggle svg {
    transform: rotate(-90deg);
  }
  .landscape-cat__body {
    transition: max-height 0.3s ease;
    overflow: visible;
    padding-top: 18px;
  }
  .landscape-cat[data-collapsed] .landscape-cat__body {
    max-height: 0 !important;
    overflow: hidden;
    padding-top: 0;
  }

  .landscape-cat__icon {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    color: white;
    flex-shrink: 0;
  }
  .landscape-cat__icon :global(svg) {
    display: block;
  }

  .landscape-cat__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 26px;
    height: 22px;
    padding: 0 7px;
    border-radius: 999px;
    color: white;
    font-size: 0.72rem;
    font-weight: 700;
    margin-left: auto;
  }

  .landscape-cat__meta {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.3;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
  }

  .landscape-subcat {
    margin-bottom: 18px;
    padding: 0 20px;
  }
  .landscape-subcat:last-child {
    margin-bottom: 14px;
  }

  .landscape-subcat__label {
    display: block;
    font-size: 0.74rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 8px;
    padding-left: 2px;
  }

  .landscape-subcat__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(76px, 1fr));
    gap: 6px;
  }

  .landscape-subcat__more {
    display: block;
    margin-top: 6px;
    padding: 4px 10px;
    border: 1px dashed var(--border);
    border-radius: 6px;
    background: transparent;
    color: var(--muted);
    font: inherit;
    font-size: 0.72rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    width: 100%;
    text-align: center;
  }
  .landscape-subcat__more:hover {
    border-color: var(--cat-accent);
    color: var(--cat-accent);
    background: var(--cat-bg);
  }
  html[data-theme='dark'] .landscape-subcat__more:hover {
    background: var(--cat-bg-dark);
  }

  .landscape-subcat__hidden .landscape-subcat__grid {
    margin-top: 4px;
  }

  @media (max-width: 720px) {
    .landscape-cat__header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 8px 10px;
      padding: 14px;
    }

    .landscape-cat__title {
      grid-column: 1;
      grid-row: 1;
      min-width: 0;
      font-size: 1.08rem;
    }

    .landscape-cat__count {
      grid-column: 2;
      grid-row: 1;
      justify-self: end;
      margin-left: 0;
      min-width: 34px;
      width: auto;
      height: 26px;
      font-size: 0.78rem;
    }

    .landscape-cat__meta {
      grid-column: 1 / -1;
      -webkit-line-clamp: 2;
      font-size: 0.82rem;
      line-height: 1.45;
    }

    .landscape-cat__toggle {
      grid-column: 1 / -1;
      width: 100%;
      min-height: 34px;
      margin-top: 2px;
      gap: 6px;
      border: 1px solid color-mix(in srgb, var(--cat-accent) 26%, var(--border));
      border-radius: 10px;
      background: rgba(255, 255, 255, 0.38);
      color: var(--cat-accent);
      font-weight: 700;
      font-size: 0.82rem;
    }

    html[data-theme='dark'] .landscape-cat__toggle {
      background: rgba(15, 23, 42, 0.24);
    }

    .landscape-cat__toggle:hover {
      background: var(--surface);
    }

    .landscape-cat__toggle-label {
      display: inline;
    }

    .landscape-subcat {
      padding: 0 14px;
    }
  }
</style>

<script>
  // Expand subcategory "more" buttons
  document.querySelectorAll('[data-expand-subcategory]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.expandSubcategory;
      const hidden = document.querySelector(`[data-subcategory-rest="${key}"]`);
      if (!hidden) return;
      const isExpanded = btn.dataset.expanded === 'true';
      if (isExpanded) {
        hidden.hidden = true;
        btn.dataset.expanded = 'false';
        btn.textContent = btn.textContent.replace('收起', `+${hidden.querySelectorAll('.landscape-card').length} ${document.documentElement.lang?.startsWith('zh') ? '更多' : 'more'}`);
      } else {
        hidden.hidden = false;
        btn.dataset.expanded = 'true';
        btn.textContent = document.documentElement.lang?.startsWith('zh') ? '收起' : 'Collapse';
      }
    });
  });

  // Collapse/expand category sections
  document.querySelectorAll('[data-cat-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.closest('.landscape-cat');
      if (!cat) return;
      cat.toggleAttribute('data-collapsed');
      const expanded = !cat.hasAttribute('data-collapsed');
      const label = expanded ? btn.dataset.labelExpanded : btn.dataset.labelCollapsed;
      const labelNode = btn.querySelector('.landscape-cat__toggle-label');
      if (labelNode && label) labelNode.textContent = label;
      if (label) {
        btn.setAttribute('aria-label', label);
        btn.setAttribute('title', label);
      }
      btn.setAttribute('aria-expanded', String(expanded));
    });
  });
</script>
